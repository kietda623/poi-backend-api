@page "/app/download"
@attribute [AllowAnonymous]
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@inject IConfiguration Configuration
@inject NavigationManager Navigation

<PageTitle>FoodStreet Download</PageTitle>

<style>
    .download-shell {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background:
            radial-gradient(circle at top left, rgba(255, 147, 77, 0.24), transparent 35%),
            radial-gradient(circle at bottom right, rgba(38, 166, 154, 0.22), transparent 30%),
            linear-gradient(135deg, #fffaf5 0%, #fff 45%, #f6fbfb 100%);
    }

    .download-card {
        width: min(100%, 560px);
        padding: 32px;
        border-radius: 28px;
        background: rgba(255, 255, 255, 0.92);
        box-shadow: 0 28px 70px rgba(31, 41, 55, 0.14);
        border: 1px solid rgba(255, 107, 53, 0.12);
    }

    .logo-wrap {
        width: 88px;
        height: 88px;
        border-radius: 24px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #ffedd5 0%, #fed7aa 100%);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.6);
        margin-bottom: 20px;
    }

    .logo-wrap img {
        width: 56px;
        height: 56px;
        object-fit: contain;
    }

    .eyebrow {
        display: inline-block;
        margin-bottom: 12px;
        padding: 6px 12px;
        border-radius: 999px;
        background: #fff3e8;
        color: #c2410c;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.02em;
    }

    .download-title {
        margin: 0 0 10px 0;
        font-size: clamp(2rem, 5vw, 2.8rem);
        line-height: 1;
        font-weight: 900;
        color: #111827;
    }

    .download-subtitle {
        margin: 0 0 24px 0;
        color: #4b5563;
        font-size: 1rem;
        line-height: 1.65;
    }

    .feature-list {
        display: grid;
        gap: 10px;
        margin: 0 0 28px 0;
    }

    .feature-item {
        padding: 12px 14px;
        border-radius: 16px;
        background: #fffaf5;
        color: #7c2d12;
        font-weight: 600;
    }

    .download-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .download-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        min-height: 52px;
        padding: 0 20px;
        border-radius: 16px;
        text-decoration: none;
        font-weight: 700;
    }

    .download-btn.primary {
        background: linear-gradient(135deg, #ff6b35 0%, #ea580c 100%);
        color: #fff;
        box-shadow: 0 16px 32px rgba(234, 88, 12, 0.24);
    }

    .download-btn.secondary {
        border: 1px solid rgba(15, 23, 42, 0.1);
        color: #1f2937;
        background: #fff;
    }

    .download-meta {
        margin-top: 18px;
        color: #6b7280;
        font-size: 0.92rem;
    }

    @@media (max-width: 640px) {
        .download-card {
            padding: 24px;
            border-radius: 22px;
        }

        .download-actions {
            flex-direction: column;
        }

        .download-btn {
            width: 100%;
        }
    }
</style>

<div class="download-shell">
    <div class="download-card">
        <div class="logo-wrap">
            <img src="@LogoUrl" alt="FoodStreet logo" />
        </div>

        <div class="eyebrow">FoodStreet Android</div>
        <h1 class="download-title">Tai app FoodStreet</h1>
        <p class="download-subtitle">@Description</p>

        <div class="feature-list">
            <div class="feature-item">Quet QR tai diem den, tai app nhanh va bat dau su dung.</div>
            <div class="feature-item">Mo app de tu dong tim POI gan nhat qua GPS.</div>
            <div class="feature-item">Nghe thuyet minh da ngon ngu ngay tren dien thoai Android.</div>
        </div>

        <div class="download-actions">
            <a class="download-btn primary" href="@AndroidApkUrl" target="_blank" rel="noopener noreferrer">
                Tai ve Android
            </a>
            <a class="download-btn secondary" href="/" rel="noopener noreferrer">
                Ve trang chu
            </a>
        </div>

        <div class="download-meta">
            File APK: <strong>@AndroidApkUrl</strong>
        </div>
    </div>
</div>

@code {
    private string AndroidApkUrl => ResolveUrl(Configuration["AppDownload:AndroidApkUrl"], "/downloads/foodstreet-android.apk");
    private string LogoUrl => ResolveUrl(Configuration["AppDownload:LogoUrl"], "/favicon.png");
    private string Description => Configuration["AppDownload:Description"]
        ?? "FoodStreet giup du khach tai app nhanh, tu dong nhan dien POI gan nhat va nghe thuyet minh da ngon ngu.";

    private string ResolveUrl(string? configuredValue, string fallback)
    {
        var value = string.IsNullOrWhiteSpace(configuredValue) ? fallback : configuredValue;
        if (Uri.TryCreate(value, UriKind.Absolute, out var absoluteUri))
        {
            return absoluteUri.ToString();
        }

        return Navigation.ToAbsoluteUri(value).ToString();
    }
}
