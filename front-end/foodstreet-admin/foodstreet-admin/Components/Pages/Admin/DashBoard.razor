@attribute [Authorize(Roles = "ADMIN")]
@page "/admin/dashboard"
@layout AdminLayout
@using MudBlazor
@inject foodstreet_admin.Services.ApiService Api
@inject foodstreet_admin.Services.StoreService StoreSvc
@inject ISnackbar Snackbar

<PageTitle>Admin Dashboard</PageTitle>

<style>
    .dashboard-container {
        animation: fadeIn 0.6s ease-out;
    }

    .stat-card {
        border-radius: 20px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(255, 255, 255, 0.12);
        position: relative;
        overflow: hidden;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.1);
    }

    .stat-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 100%);
        pointer-events: none;
    }

    .glass-panel {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .gradient-text {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 800;
    }

    .card-icon-container {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 12px;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .quick-action-btn {
        border-radius: 16px;
        height: 56px;
        text-transform: none;
        font-weight: 600;
        letter-spacing: 0;
        transition: all 0.2s;
    }

    .quick-action-btn:hover {
        filter: brightness(1.1);
        transform: scale(1.02);
    }
</style>

<div class="dashboard-container">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6">
        <div>
            <MudText Typo="Typo.h4" Class="gradient-text">Hệ thống Quản trị</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Chào mừng trở lại, Admin. Đây là tổng quan hệ thống hôm nay.</MudText>
        </div>
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" 
                   OnClick="LoadData" Style="border-radius: 12px;">Làm mới dữ liệu</MudButton>
    </MudStack>

    <!-- Stats Overview -->
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-5 stat-card" Elevation="0" Style="background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%); border-color: #bae6fd;">
                <div class="card-icon-container" style="background: #ffffff; color: #0284c7; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1)">
                    <MudIcon Icon="@Icons.Material.Filled.Store" Size="Size.Medium" />
                </div>
                <MudText Typo="Typo.h4" Style="font-weight:800; color: #0369a1">@totalStores</MudText>
                <MudText Typo="Typo.body2" Style="color: #075985; font-weight: 600">Tổng gian hàng</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-5 stat-card" Elevation="0" Style="background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); border-color: #a7f3d0;">
                <div class="card-icon-container" style="background: #ffffff; color: #059669; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1)">
                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Medium" />
                </div>
                <MudText Typo="Typo.h4" Style="font-weight:800; color: #047857">@totalRevenue.ToString("N0")</MudText>
                <MudText Typo="Typo.body2" Style="color: #065f46; font-weight: 600">Doanh thu (VND)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-5 stat-card" Elevation="0" Style="background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%); border-color: #fde68a;">
                <div class="card-icon-container" style="background: #ffffff; color: #d97706; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1)">
                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Medium" />
                </div>
                <MudText Typo="Typo.h4" Style="font-weight:800; color: #b45309">@totalCustomers</MudText>
                <MudText Typo="Typo.body2" Style="color: #92400e; font-weight: 600">Khách đăng ký</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-5 stat-card" Elevation="0" Style="background: linear-gradient(135deg, #fdf2f8 0%, #fce7f3 100%); border-color: #fbcfe8;">
                <div class="card-icon-container" style="background: #ffffff; color: #db2777; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1)">
                    <MudIcon Icon="@Icons.Material.Filled.Headphones" Size="Size.Medium" />
                </div>
                <MudText Typo="Typo.h4" Style="font-weight:800; color: #be185d">@totalListens.ToString("N0")</MudText>
                <MudText Typo="Typo.body2" Style="color: #9d174d; font-weight: 600">Lượt nghe Audio</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid>
        <!-- Revenue & Listens Chart -->
        <MudItem xs="12" lg="8">
            <MudPaper Class="pa-6 glass-panel border-0" Elevation="0">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6">
                    <MudIcon Icon="@Icons.Material.Filled.Insights" Color="Color.Primary" />
                    <MudText Typo="Typo.h6" Style="font-weight:800">Hiệu suất Hệ thống (2026)</MudText>
                    <MudSpacer />
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        <MudMenuItem Icon="@Icons.Material.Filled.FileDownload">Xuất báo cáo</MudMenuItem>
                    </MudMenu>
                </MudStack>
                
                @if (adminChartSeries.Any())
                {
                    <MudChart ChartType="ChartType.Bar" ChartSeries="@adminChartSeries" @bind-SelectedIndex="adminChartIndex" 
                              XAxisLabels="@adminXAxisLabels" Width="100%" Height="400px" 
                              ChartOptions="@_chartOptions" />
                }
                else
                {
                    <div class="d-flex align-center justify-center" style="height: 400px; opacity: 0.5;">
                        <MudText>Không có dữ liệu biểu đồ</MudText>
                    </div>
                }
            </MudPaper>
        </MudItem>

        <!-- Top Performing Shops -->
        <MudItem xs="12" lg="4">
            <MudPaper Class="pa-6 glass-panel border-0" Elevation="0" Style="height: 100%;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6">
                    <MudIcon Icon="@Icons.Material.Filled.Stars" Color="Color.Warning" />
                    <MudText Typo="Typo.h6" Style="font-weight:800">Top Gian hàng</MudText>
                </MudStack>
                
                @if (topShops.Any())
                {
                    <MudList T="string" Dense="true" Class="pa-0">
                        @foreach (var (shop, index) in topShops.Select((s, i) => (s, i)))
                        {
                            <MudListItem T="string" Class="pa-3 mb-3" Style="background: rgba(255,255,255,0.5); border-radius: 12px; border: 1px solid rgba(0,0,0,0.03);">
                                <div class="d-flex align-center">
                                    <div class="mr-3 d-flex align-center justify-center" style="width: 32px; height: 32px; background: @(index == 0 ? "#fef3c7" : index == 1 ? "#f1f5f9" : "#fff7ed"); border-radius: 8px; color: @(index == 0 ? "#b45309" : index == 1 ? "#475569" : "#c2410c"); font-weight: 800; font-size: 0.8rem;">
                                        @(index + 1)
                                    </div>
                                    <div style="flex: 1; overflow: hidden;">
                                        <MudText Typo="Typo.body2" Style="font-weight:700; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@shop.ShopName</MudText>
                                        <MudText Typo="Typo.caption" Style="color: #64748b;">@shop.OrderCount đơn hàng</MudText>
                                    </div>
                                    <div class="ml-2 text-right">
                                        <MudText Typo="Typo.body2" Style="font-weight:800; color: #10b981;">@shop.Revenue.ToString("N0")</MudText>
                                        <MudText Typo="Typo.caption" Style="color: #94a3b8;">VND</MudText>
                                    </div>
                                </div>
                            </MudListItem>
                        }
                    </MudList>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="text-center">Chưa có dữ liệu giao dịch</MudAlert>
                }

                <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/admin/stats"
                           EndIcon="@Icons.Material.Filled.ArrowForward" Class="mt-2" Style="text-transform: none;">
                    Xem chi tiết thống kê
                </MudButton>
            </MudPaper>
        </MudItem>

        <!-- Quick Access -->
        <MudItem xs="12">
            <MudPaper Class="pa-6 glass-panel border-0" Elevation="0">
                <MudText Typo="Typo.h6" Style="font-weight:800" Class="mb-5">Công cụ Quản lý nhanh</MudText>
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Href="/admin/manage-seller" Variant="Variant.Filled" Color="Color.Primary" 
                                   StartIcon="@Icons.Material.Filled.SupervisorAccount" FullWidth="true"
                                   Class="quick-action-btn" Style="background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);">
                            Quản lý Người bán
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Href="/admin/manage-store" Variant="Variant.Filled" Color="Color.Success" 
                                   StartIcon="@Icons.Material.Filled.Storefront" FullWidth="true"
                                   Class="quick-action-btn" Style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                            Duyệt Gian hàng
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Href="/admin/manage-customer" Variant="Variant.Filled" Color="Color.Info" 
                                   StartIcon="@Icons.Material.Filled.People" FullWidth="true"
                                   Class="quick-action-btn" Style="background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);">
                            Khách truy cập
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Href="/admin/settings" Variant="Variant.Filled" Color="Color.Secondary" 
                                   StartIcon="@Icons.Material.Filled.Settings" FullWidth="true"
                                   Class="quick-action-btn" Style="background: linear-gradient(135deg, #64748b 0%, #475569 100%);">
                            Cấu hình Hệ thống
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
    </MudGrid>
</div>

@code {
    private int totalStores;
    private int totalCustomers;
    private int totalListens;
    private decimal totalRevenue;

    private List<foodstreet_admin.Models.ShopRevenueItem> topShops = new();
    private List<ChartSeries<double>> adminChartSeries = new();
    private string[] adminXAxisLabels = Array.Empty<string>();
    private int adminChartIndex = -1;
    private ChartOptions _chartOptions = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var year = DateTime.UtcNow.Year;
        var stats = await StoreSvc.GetAdminStatsAsync(year);
        
        if (stats != null)
        {
            totalListens = stats.TotalListens;
            totalRevenue = stats.TotalRevenue;
            
            // Xử lý dữ liệu biểu đồ
            var monthlyData = stats.RevenueByMonth
                .OrderBy(x => x.Month)
                .ToList();
                
            adminXAxisLabels = monthlyData.Select(m => $"T{m.Month}").ToArray();
            
            adminChartSeries = new List<ChartSeries<double>>()
            {
                new ChartSeries<double>() { Name = "Doanh thu", Data = monthlyData.Select(m => (double)m.Revenue).ToArray() },
                new ChartSeries<double>() { Name = "Lượt nghe", Data = monthlyData.Select(m => (double)(stats.ListensByMonth.FirstOrDefault(x => x.Month == m.Month)?.Listens ?? 0)).ToArray() }
            };

            // Lấy Top 5 Shops
            topShops = stats.RevenueByShop
                .OrderByDescending(s => s.Revenue)
                .Take(5)
                .ToList();
        }

        var stores = await StoreSvc.GetStoresAsync();
        totalStores = stores.Count;

        var customers = await StoreSvc.GetCustomersAsync();
        totalCustomers = customers.Count;
        
        StateHasChanged();
    }
}
