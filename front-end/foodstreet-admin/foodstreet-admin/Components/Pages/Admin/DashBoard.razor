@attribute [Authorize(Roles = "ADMIN")]
@page "/admin/dashboard"
@layout AdminLayout
@using MudBlazor
@implements IAsyncDisposable
@inject foodstreet_admin.Services.ApiService Api
@inject foodstreet_admin.Services.StoreService StoreSvc
@inject ISnackbar Snackbar
@inject IConfiguration Configuration
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Admin Dashboard</PageTitle>

<style>
    .dashboard-container {
        animation: fadeIn 0.6s ease-out;
    }

    .stat-card {
        border-radius: 20px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(255, 255, 255, 0.12);
        position: relative;
        overflow: hidden;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.1);
    }

    .glass-panel {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .gradient-text {
        background: linear-gradient(135deg, #f97316 0%, #ea580c 40%, #0f766e 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 800;
    }

    .card-icon-container {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 12px;
    }

    .quick-action-btn {
        border-radius: 16px;
        height: 56px;
        text-transform: none;
        font-weight: 600;
        letter-spacing: 0;
        transition: all 0.2s;
    }

    .stats-grid {
        display: grid;
        gap: 24px;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        margin-bottom: 24px;
    }

    .download-qr-card {
        background: radial-gradient(circle at top left, rgba(255, 183, 77, 0.26), transparent 30%), linear-gradient(135deg, #fff9f3 0%, #ffffff 45%, #f4fbfa 100%);
    }

    .download-qr-image {
        width: min(100%, 280px);
        aspect-ratio: 1;
        padding: 16px;
        border-radius: 24px;
        background: #fff;
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
    }

    .download-qr-image img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="dashboard-container">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6">
        <div>
            <MudText Typo="Typo.h4" Class="gradient-text">Hệ thống Quản trị</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Tổng quan vận hành và thống kê doanh thu</MudText>
        </div>
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="LoadData" Style="border-radius: 12px;">
            Làm mới
        </MudButton>
    </MudStack>

    <div class="stats-grid">
        <MudPaper Class="pa-5 stat-card" Elevation="0" Style="background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); border-color: #a7f3d0;">
            <div class="card-icon-container" style="background: #ffffff; color: #059669; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1)">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Medium" />
            </div>
            <MudText Typo="Typo.h4" Style="font-weight:800; color: #047857">@totalPlatformRevenue.ToString("N0")</MudText>
            <MudText Typo="Typo.body2" Style="color: #065f46; font-weight: 600">Tổng doanh thu (VNĐ)</MudText>
        </MudPaper>

        <MudPaper Class="pa-5 stat-card" Elevation="0" Style="background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%); border-color: #bae6fd;">
            <div class="card-icon-container" style="background: #ffffff; color: #0284c7; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1)">
                <MudIcon Icon="@Icons.Material.Filled.Store" Size="Size.Medium" />
            </div>
            <MudText Typo="Typo.h4" Style="font-weight:800; color: #0369a1">@totalStores</MudText>
            <MudText Typo="Typo.body2" Style="color: #075985; font-weight: 600">Tổng gian hàng</MudText>
        </MudPaper>

        <MudPaper Class="pa-5 stat-card" Elevation="0" Style="background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%); border-color: #fde68a;">
            <div class="card-icon-container" style="background: #ffffff; color: #d97706; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1)">
                <MudIcon Icon="@Icons.Material.Filled.SupervisorAccount" Size="Size.Medium" />
            </div>
            <MudText Typo="Typo.h4" Style="font-weight:800; color: #b45309">@totalSellers</MudText>
            <MudText Typo="Typo.body2" Style="color: #92400e; font-weight: 600">Người bán (Seller)</MudText>
        </MudPaper>

        <MudPaper Class="pa-5 stat-card" Elevation="0" Style="background: linear-gradient(135deg, #faf5ff 0%, #f3e8ff 100%); border-color: #e9d5ff;">
            <div class="card-icon-container" style="background: #ffffff; color: #9333ea; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1)">
                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Medium" />
            </div>
            <MudText Typo="Typo.h4" Style="font-weight:800; color: #7e22ce">@totalCustomers</MudText>
            <MudText Typo="Typo.body2" Style="color: #6b21a8; font-weight: 600">Khách đăng ký (User)</MudText>
        </MudPaper>

        <MudPaper Class="pa-5 stat-card" Elevation="0" Style="background: linear-gradient(135deg, #fdf2f8 0%, #fce7f3 100%); border-color: #fbcfe8;">
            <div class="card-icon-container" style="background: #ffffff; color: #db2777; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1)">
                <MudIcon Icon="@Icons.Material.Filled.Headphones" Size="Size.Medium" />
            </div>
            <MudText Typo="Typo.h4" Style="font-weight:800; color: #be185d">@totalListens.ToString("N0")</MudText>
            <MudText Typo="Typo.body2" Style="color: #9d174d; font-weight: 600">Tổng lượt nghe audio</MudText>
            <div style="margin-top: 8px; display: flex; gap: 12px;">
                <MudText Typo="Typo.caption" Style="color: #be185d;"><b>@registeredListens.ToString("N0")</b> User</MudText>
                <MudText Typo="Typo.caption" Style="color: #9d174d;"><b>@guestListens.ToString("N0")</b> Guest</MudText>
            </div>
        </MudPaper>

        <MudPaper Class="pa-5 stat-card" Elevation="0" Style="background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%); border-color: #86efac;">
            <div class="card-icon-container" style="background: #ffffff; color: #16a34a; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1)">
                <MudIcon Icon="@Icons.Material.Filled.PhoneAndroid" Size="Size.Medium" />
            </div>
            <MudText Typo="Typo.h4" Style="font-weight:800; color: #15803d">@onlineAppUsers</MudText>
            <MudText Typo="Typo.body2" Style="color: #166534; font-weight: 600">Du khách đang online</MudText>
        </MudPaper>
    </div>

    <MudGrid>
        <MudItem xs="12" lg="8">
            <MudPaper Class="pa-6 glass-panel border-0" Elevation="0">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6">
                    <MudIcon Icon="@Icons.Material.Filled.Insights" Color="Color.Primary" />
                    <MudText Typo="Typo.h6" Style="font-weight:800">Biểu đồ Doanh thu (Phần nhận được) - @DateTime.UtcNow.Year</MudText>
                </MudStack>

                @if (adminChartSeries.Any())
                {
                    <MudChart T="double" ChartType="ChartType.StackedBar" ChartSeries="@adminChartSeries" @bind-SelectedIndex="adminChartIndex"
                              ChartLabels="@adminXAxisLabels" Width="100%" Height="400px"
                              ChartOptions="@_chartOptions" />
                }
                else
                {
                    <div class="d-flex align-center justify-center" style="height: 400px; opacity: 0.5;">
                        <MudText>Không có dữ liệu biểu đồ</MudText>
                    </div>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="4">
            <MudPaper Class="pa-6 glass-panel border-0" Elevation="0" Style="height: 100%;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6">
                    <MudIcon Icon="@Icons.Material.Filled.Stars" Color="Color.Warning" />
                    <MudText Typo="Typo.h6" Style="font-weight:800">Top gian hàng đóng góp</MudText>
                </MudStack>

                @if (topSellers.Any())
                {
                    <MudList T="string" Dense="true" Class="pa-0">
                        @foreach (var (seller, index) in topSellers.Select((s, i) => (s, i)))
                        {
                            <MudListItem T="string" Class="pa-3 mb-3" Style="background: rgba(255,255,255,0.5); border-radius: 12px; border: 1px solid rgba(0,0,0,0.03);">
                                <div class="d-flex align-center">
                                    <div class="mr-3 d-flex align-center justify-center" style="width: 32px; height: 32px; background: @(index == 0 ? "#fef3c7" : index == 1 ? "#f1f5f9" : "#fff7ed"); border-radius: 8px; color: @(index == 0 ? "#b45309" : index == 1 ? "#475569" : "#c2410c"); font-weight: 800; font-size: 0.8rem;">
                                        @(index + 1)
                                    </div>
                                    <div style="flex: 1; overflow: hidden;">
                                        <MudText Typo="Typo.body2" Style="font-weight:700; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@seller.SellerName</MudText>
                                        <MudText Typo="Typo.caption" Style="color: #64748b;">@seller.PackageName • @seller.SubscriptionCount GD</MudText>
                                    </div>
                                    <div class="ml-2 text-right">
                                        <MudText Typo="Typo.body2" Style="font-weight:800; color: #10b981;">@seller.Revenue.ToString("N0")</MudText>
                                        <MudText Typo="Typo.caption" Style="color: #94a3b8;">VNĐ</MudText>
                                    </div>
                                </div>
                            </MudListItem>
                        }
                    </MudList>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="text-center">Chưa có dữ liệu giao dịch</MudAlert>
                }

                <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/admin/stats"
                           EndIcon="@Icons.Material.Filled.ArrowForward" Class="mt-2" Style="text-transform: none;">
                    Xem chi tiết thống kê
                </MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="4">
            <MudPaper Class="pa-6 glass-panel border-0" Elevation="0">
                <MudText Typo="Typo.h6" Style="font-weight:800" Class="mb-5">Tỷ lệ Doanh thu</MudText>
                
                @if (totalPlatformRevenue > 0)
                {
                    <MudChart T="double" ChartType="ChartType.Pie" ChartSeries="@pieChartSeries" ChartLabels="@pieChartLabels" Width="100%" Height="250px" />
                }
                else
                {
                    <div class="d-flex align-center justify-center" style="height: 250px; opacity: 0.5;">
                        <MudText>Chưa có dữ liệu</MudText>
                    </div>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="8">
            <MudPaper Class="pa-6 border-0 download-qr-card" Elevation="0" Style="border-radius: 24px; height: 100%;">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.QrCode2" Color="Color.Warning" />
                        <MudText Typo="Typo.h6" Style="font-weight:800">QR tải app dùng chung</MudText>
                    </MudStack>

                    <MudText Typo="Typo.body2" Style="color:#4b5563;">
                        In mã này và dán tại các POI/gian hàng. Khách quét mã sẽ mở trang download công khai của FoodStreet.
                    </MudText>

                    <div class="download-qr-image" style="width: 200px;">
                        <img src="@AppDownloadQrImageUrl" alt="FoodStreet app download QR" />
                    </div>

                    <MudPaper Elevation="0" Class="pa-3" Style="background: rgba(255,255,255,0.82); border-radius: 16px;">
                        <MudText Typo="Typo.caption" Style="display:block; opacity:0.7;">Landing page công khai</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight:700; word-break:break-all;">@PublicDownloadUrl</MudText>
                    </MudPaper>

                    <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Print" OnClick="PrintAppQrAsync">
                            In QR
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Download" OnClick="DownloadAppQrAsync">
                            Tải PNG
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Class="pa-6 glass-panel border-0" Elevation="0">
                <MudText Typo="Typo.h6" Style="font-weight:800" Class="mb-5">Công cụ quản lý nhanh</MudText>
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Href="/admin/manage-seller" Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.SupervisorAccount" FullWidth="true"
                                   Class="quick-action-btn" Style="background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);">
                            Người bán
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Href="/admin/manage-store" Variant="Variant.Filled" Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.Storefront" FullWidth="true"
                                   Class="quick-action-btn" Style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                            Duyệt gian hàng
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Href="/admin/manage-service-package" Variant="Variant.Filled" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.CardMembership" FullWidth="true"
                                   Class="quick-action-btn" Style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);">
                            Gói dịch vụ
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Href="/admin/settings" Variant="Variant.Filled" Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.Settings" FullWidth="true"
                                   Class="quick-action-btn" Style="background: linear-gradient(135deg, #64748b 0%, #475569 100%);">
                            Cấu hình
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
    </MudGrid>
</div>

@code {
    private decimal totalPlatformRevenue;
    private int totalStores;
    private int totalSellers;
    private int totalCustomers;
    
    private int totalListens;
    private int guestListens;
    private int registeredListens;
    private int onlineAppUsers;

    private List<foodstreet_admin.Models.SellerRevenueDetail> topSellers = new();
    
    // Stacked Bar Chart
    private List<ChartSeries<double>> adminChartSeries = new();
    private string[] adminXAxisLabels = Array.Empty<string>();
    private int adminChartIndex = -1;
    private ChartOptions _chartOptions = new() { ChartPalette = new string[] { "#0369a1", "#d97706" } };

    // Pie Chart
    private List<ChartSeries<double>> pieChartSeries = new();
    private string[] pieChartLabels = Array.Empty<string>();

    private CancellationTokenSource? _onlineCountCts;
    private Task? _onlineCountTask;

    private string PublicDownloadUrl => Configuration["AppDownload:PublicDownloadUrl"] ?? "https://foodstreet.vn/app/download";
    private string AppDownloadQrImageUrl => $"https://api.qrserver.com/v1/create-qr-code/?size=320x320&data={Uri.EscapeDataString(PublicDownloadUrl)}";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        StartOnlineCountPolling();
    }

    private async Task LoadData()
    {
        var year = DateTime.UtcNow.Year;
        var stats = await StoreSvc.GetAdminStatsAsync(year);

        if (stats != null)
        {
            // Update summary
            totalPlatformRevenue = stats.Summary.TotalRevenue;

            totalListens = stats.TotalListens;
            guestListens = stats.GuestListens;
            registeredListens = stats.RegisteredListens;

            // Monthly Breakdown - Stacked Bar Chart
            var monthlyData = stats.RevenueByMonth.OrderBy(x => x.Month).ToList();
            adminXAxisLabels = monthlyData.Select(m => $"T{m.Month}").ToArray();

            adminChartSeries = new List<ChartSeries<double>>
            {
                new() { Name = "Seller Revenue", Data = monthlyData.Select(m => (double)m.SellerRevenue).ToArray() },
                new() { Name = "User Share", Data = monthlyData.Select(m => (double)m.UserRevenue).ToArray() }
            };

            // Pie Chart
            var sr = (double)stats.Summary.SellerRevenue;
            var ur = (double)stats.Summary.PlatformShare;
            pieChartSeries = new List<ChartSeries<double>>
            {
                new() { Name = "Seller", Data = new double[] { sr } },
                new() { Name = "User Share", Data = new double[] { ur } }
            };
            pieChartLabels = new string[] { $"Seller ({stats.Summary.SellerRevenue:N0})", $"User ({stats.Summary.PlatformShare:N0})" };

            // Top Sellers
            topSellers = stats.SellerStats.BySeller
                .OrderByDescending(s => s.Revenue)
                .Take(5)
                .ToList();
        }

        // Load counts
        var stores = await StoreSvc.GetStoresAsync();
        totalStores = stores.Count;

        var sellers = await StoreSvc.GetSellersAsync();
        totalSellers = sellers.Count;

        var customers = await StoreSvc.GetCustomersAsync();
        totalCustomers = customers.Count;

        await LoadOnlineCountAsync();
        StateHasChanged();
    }

    private async Task LoadOnlineCountAsync()
    {
        onlineAppUsers = await StoreSvc.GetOnlineCountAsync();
    }

    private void StartOnlineCountPolling()
    {
        if (_onlineCountTask != null) return;
        _onlineCountCts = new CancellationTokenSource();
        _onlineCountTask = PollOnlineCountAsync(_onlineCountCts.Token);
    }

    private async Task PollOnlineCountAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                var count = await StoreSvc.GetOnlineCountAsync();
                if (count == onlineAppUsers) continue;
                onlineAppUsers = count;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task DownloadAppQrAsync()
    {
        await JS.InvokeVoidAsync("downloadFileFromUrl", AppDownloadQrImageUrl, "foodstreet-app-download-qr.png");
    }

    private async Task PrintAppQrAsync()
    {
        await JS.InvokeVoidAsync("printQrImage", AppDownloadQrImageUrl, "FoodStreet App Download QR");
    }

    public async ValueTask DisposeAsync()
    {
        if (_onlineCountCts is not null)
        {
            await _onlineCountCts.CancelAsync();
            _onlineCountCts.Dispose();
            _onlineCountCts = null;
        }

        if (_onlineCountTask is not null)
        {
            try { await _onlineCountTask; } catch (OperationCanceledException) { }
            _onlineCountTask = null;
        }
    }
}
