@attribute [Authorize(Roles = "Admin")]
@page "/admin/settings"
@rendermode InteractiveServer
@using MudBlazor

<PageTitle>Cài đặt hệ thống</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">⚙️ Cài đặt hệ thống</MudText>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

    <!-- Language Management -->
    <MudTabPanel Text="🌐 Quản lý ngôn ngữ" Icon="@Icons.Material.Filled.Language">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6" Class="mb-3">Ngôn ngữ đang hỗ trợ</MudText>
                <MudTable Items="@languages" Hover="true" Dense="true" Striped="true">
                    <HeaderContent>
                        <MudTh>Mã ngôn ngữ</MudTh>
                        <MudTh>Tên</MudTh>
                        <MudTh>Trạng thái</MudTh>
                        <MudTh>Thao tác</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Code</MudTd>
                        <MudTd>@context.Name</MudTd>
                        <MudTd>
                            <MudSwitch @bind-Value="context.IsActive" Color="Color.Success" Size="Size.Small" />
                        </MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error" OnClick="@(() => DeleteLanguage(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
                <MudStack Row="true" Class="mt-3" Spacing="2">
                    <MudTextField @bind-Value="newLangCode" Label="Mã (vd: en, ja)" Variant="Variant.Outlined" Dense="true" />
                    <MudTextField @bind-Value="newLangName" Label="Tên (vd: English)" Variant="Variant.Outlined" Dense="true" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddLanguage"
                               StartIcon="@Icons.Material.Filled.Add">Thêm</MudButton>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudAlert Severity="Severity.Info" Class="mb-3">
                    Khi thêm ngôn ngữ mới, hệ thống sẽ tạo file .resx tương ứng và yêu cầu dịch nội dung.
                </MudAlert>
                <MudText Typo="Typo.body2">
                    Ngôn ngữ mặc định: <MudChip T="string" Color="Color.Primary" Size="Size.Small">vi-VN</MudChip>
                </MudText>
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    <!-- Payment Config -->
    <MudTabPanel Text="💰 Cấu hình phí" Icon="@Icons.Material.Filled.Payment">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6" Class="mb-3">Phí thanh toán</MudText>
                <MudNumericField @bind-Value="monthlyFee" Label="Phí tháng (VNĐ)"
                                 Variant="Variant.Outlined" Class="mb-3" Format="N0" />
                <MudNumericField @bind-Value="yearlyFee" Label="Phí năm (VNĐ)"
                                 Variant="Variant.Outlined" Class="mb-3" Format="N0" />
                <MudNumericField @bind-Value="transactionFeePercent" Label="Phí giao dịch (%)"
                                 Variant="Variant.Outlined" Class="mb-3"
                                 Min="0" Max="100" Step="0.1" />
                <MudButton Variant="Variant.Filled" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Save" OnClick="SavePaymentConfig">
                    Lưu cấu hình phí
                </MudButton>
                @if (paymentSaved)
                {
                    <MudAlert Severity="Severity.Success" Class="mt-2">Đã lưu!</MudAlert>
                }
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6" Class="mb-3">Cổng thanh toán</MudText>
                <MudSelect @bind-Value="paymentGateway" Label="Cổng thanh toán" Variant="Variant.Outlined" Class="mb-3">
                    <MudSelectItem Value="@("vnpay")">VNPay</MudSelectItem>
                    <MudSelectItem Value="@("momo")">MoMo</MudSelectItem>
                    <MudSelectItem Value="@("zalopay")">ZaloPay</MudSelectItem>
                    <MudSelectItem Value="@("stripe")">Stripe</MudSelectItem>
                </MudSelect>
                <MudTextField @bind-Value="paymentApiKey" Label="API Key" Variant="Variant.Outlined"
                              InputType="InputType.Password" Class="mb-3" />
                <MudTextField @bind-Value="paymentSecretKey" Label="Secret Key" Variant="Variant.Outlined"
                              InputType="InputType.Password" />
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    <!-- Database & Backup -->
    <MudTabPanel Text="🗄️ Database & Backup" Icon="@Icons.Material.Filled.Storage">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6" Class="mb-3">Backup Database</MudText>
                <MudPaper Class="pa-4" Elevation="1" Style="background:#f5f5f5;">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.body2">
                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Class="mr-1" />
                            Backup gần nhất: <b>12/05/2025 02:00</b>
                        </MudText>
                        <MudText Typo="Typo.body2">
                            <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" Class="mr-1" />
                            Dung lượng backup: <b>245 MB</b>
                        </MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Backup" OnClick="RunBackup">
                            Backup ngay
                        </MudButton>
                        @if (backupRunning)
                        {
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                            <MudText Typo="Typo.caption">Đang backup...</MudText>
                        }
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6" Class="mb-3">Lịch backup tự động</MudText>
                <MudSelect @bind-Value="backupSchedule" Label="Tần suất" Variant="Variant.Outlined" Class="mb-3">
                    <MudSelectItem Value="@("daily")">Hàng ngày (02:00 AM)</MudSelectItem>
                    <MudSelectItem Value="@("weekly")">Hàng tuần (Chủ nhật)</MudSelectItem>
                    <MudSelectItem Value="@("monthly")">Hàng tháng (Ngày 1)</MudSelectItem>
                </MudSelect>
                <MudButton Variant="Variant.Outlined" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Schedule" OnClick="SaveBackupSchedule">
                    Lưu lịch backup
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    <!-- Audit Log -->
    <MudTabPanel Text="📋 Audit Log" Icon="@Icons.Material.Filled.History">
        <MudText Typo="Typo.h6" Class="mb-3">Lịch sử hoạt động hệ thống</MudText>
        <MudTable Items="@auditLogs" Hover="true" Dense="true" Striped="true">
            <HeaderContent>
                <MudTh>Thời gian</MudTh>
                <MudTh>Người dùng</MudTh>
                <MudTh>Hành động</MudTh>
                <MudTh>Chi tiết</MudTh>
                <MudTh>IP</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Timestamp</MudTd>
                <MudTd>@context.User</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.Action.StartsWith("DELETE") ? Color.Error : context.Action.StartsWith("APPROVE") ? Color.Success : Color.Info)">
                        @context.Action
                    </MudChip>
                </MudTd>
                <MudTd>@context.Detail</MudTd>
                <MudTd>@context.Ip</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[]{10, 25}" />
            </PagerContent>
        </MudTable>
    </MudTabPanel>

</MudTabs>

@code {
    // Language
    private string newLangCode = "";
    private string newLangName = "";
    private record Language(string Code, string Name) { public bool IsActive { get; set; } = true; }
    private List<Language> languages = new()
    {
        new("vi", "Tiếng Việt") { IsActive = true },
        new("en", "English") { IsActive = true },
        new("zh", "中文") { IsActive = false },
        new("ja", "日本語") { IsActive = false },
    };

    // Payment
    private decimal monthlyFee = 99000;
    private decimal yearlyFee = 990000;
    private double transactionFeePercent = 2.5;
    private string paymentGateway = "vnpay";
    private string paymentApiKey = "";
    private string paymentSecretKey = "";
    private bool paymentSaved = false;

    // Backup
    private bool backupRunning = false;
    private string backupSchedule = "daily";

    // Audit logs
    private record AuditLog(string Timestamp, string User, string Action, string Detail, string Ip);
    private List<AuditLog> auditLogs = new()
    {
        new("13/05/2025 10:35", "admin@sys.com", "APPROVE", "Duyệt gian hàng #12", "192.168.1.1"),
        new("13/05/2025 10:20", "admin@sys.com", "DISABLE_SELLER", "Vô hiệu hóa seller #5", "192.168.1.1"),
        new("12/05/2025 15:00", "admin@sys.com", "DELETE", "Xóa gian hàng vi phạm #8", "192.168.1.2"),
        new("12/05/2025 09:00", "system", "BACKUP", "Backup tự động thành công", "localhost"),
        new("11/05/2025 14:30", "admin@sys.com", "UPDATE_CONFIG", "Cập nhật phí tháng", "192.168.1.1"),
    };

    private void AddLanguage()
    {
        if (!string.IsNullOrWhiteSpace(newLangCode) && !string.IsNullOrWhiteSpace(newLangName))
        {
            languages.Add(new Language(newLangCode, newLangName));
            newLangCode = newLangName = "";
        }
    }

    private void DeleteLanguage(Language lang) => languages.Remove(lang);

    private void SavePaymentConfig() => paymentSaved = true;

    private async Task RunBackup()
    {
        backupRunning = true;
        await Task.Delay(2000); // Simulate backup
        backupRunning = false;
    }

    private void SaveBackupSchedule() { /* TODO */ }
}
