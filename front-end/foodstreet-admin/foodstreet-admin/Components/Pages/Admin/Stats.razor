@attribute [Authorize(Roles = "ADMIN")]
@page "/admin/stats"
@layout AdminLayout
@rendermode InteractiveServer
@using MudBlazor
@inject foodstreet_admin.Services.StoreService StoreSvc

<PageTitle>Thống kê doanh thu</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Thống kê doanh thu</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.PictureAsPdf"
               Color="Color.Error" Size="Size.Small" Class="mr-2">Export CSV</MudButton>
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.TableChart"
               Color="Color.Success" Size="Size.Small">Export PDF</MudButton>
</MudStack>

<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudGrid AlignItems="AlignItems.Center">
        <MudItem xs="12" md="4">
            <MudSelect T="int" @bind-Value="filterYear" Label="Năm" Variant="Variant.Outlined" Dense="true">
                @for (int y = DateTime.Now.Year; y >= 2024; y--)
                {
                    int currentYear = y;
                    <MudSelectItem Value="@currentYear">@currentYear</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudSelect T="int" @bind-Value="filterMonth" Label="Tháng" Variant="Variant.Outlined" Dense="true">
                <MudSelectItem Value="0">Tất cả (cả năm)</MudSelectItem>
                @for (int m = 1; m <= 12; m++)
                {
                    int currentMonth = m;
                    <MudSelectItem Value="@currentMonth">Tháng @currentMonth</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search"
                       OnClick="LoadRevenue" FullWidth="true">Lọc doanh thu</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Class="pa-4 text-center mb-4" Elevation="2">
    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Warning" Size="Size.Large" />
    <MudText Typo="MudBlazor.Typo.h4" Color="Color.Warning"><b>@totalRevenue.ToString("N0") đ</b></MudText>
    <MudText Typo="MudBlazor.Typo.body2">Tổng doanh thu</MudText>
</MudPaper>

@if (isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Doanh thu theo tháng (@filterYear)</MudText>
            <MudTable Items="@revenueByMonth" Hover="true" Dense="true" Striped="true">
                <HeaderContent>
                    <MudTh>Tháng</MudTh>
                    <MudTh>Đơn hàng</MudTh>
                    <MudTh>Doanh thu</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>Tháng @context.Month</MudTd>
                    <MudTd>@context.OrderCount</MudTd>
                    <MudTd>
                        <MudProgressLinear Value="@GetRevenueProgress(context.Revenue)" Color="Color.Warning" Rounded="true" Class="my-1" />
                        <MudText Typo="Typo.caption">@FormatCurrency(context.Revenue)</MudText>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText>Chua co du lieu doanh thu.</MudText>
                </NoRecordsContent>
            </MudTable>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Doanh thu theo cửa hàng</MudText>
            <MudTable Items="@revenueByShop" Hover="true" Dense="true" Striped="true">
                <HeaderContent>
                    <MudTh>#</MudTh>
                    <MudTh>Cửa hàng</MudTh>
                    <MudTh>Đơn hàng</MudTh>
                    <MudTh>Doanh thu</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@(revenueByShop.IndexOf(context) + 1)</MudTd>
                    <MudTd>@context.ShopName</MudTd>
                    <MudTd>@context.OrderCount</MudTd>
                    <MudTd>
                        <MudProgressLinear Value="@GetRevenueProgress(context.Revenue)" Color="Color.Warning" Rounded="true" Class="my-1" />
                        <MudText Typo="Typo.caption">@FormatCurrency(context.Revenue)</MudText>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText>Chưa có dữ liệu doanh thu.</MudText>
                </NoRecordsContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private int filterYear = DateTime.Now.Year;
    private int filterMonth = 0;
    private decimal totalRevenue;
    private bool isLoading;
    private List<foodstreet_admin.Models.ShopRevenueItem> revenueByShop = new();
    private List<foodstreet_admin.Models.MonthlyRevenueItem> revenueByMonth = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadRevenue();
    }

    private async Task LoadRevenue()
    {
        isLoading = true;
        StateHasChanged();

        int? month = filterMonth > 0 ? filterMonth : null;
        var revenue = await StoreSvc.GetAdminRevenueAsync(month, filterYear);

        if (revenue != null)
        {
            totalRevenue = revenue.TotalRevenue;
            revenueByShop = revenue.RevenueByShop;
            revenueByMonth = revenue.RevenueByMonth;
        }
        else
        {
            totalRevenue = 0;
            revenueByShop = new();
            revenueByMonth = new();
        }

        isLoading = false;
        StateHasChanged();
    }

    private decimal GetRevenueMax()
    {
        var maxMonth = revenueByMonth.Any() ? revenueByMonth.Max(x => x.Revenue) : 0;
        var maxShop = revenueByShop.Any() ? revenueByShop.Max(x => x.Revenue) : 0;
        return new[] { totalRevenue, maxMonth, maxShop }.Max();
    }

    private double GetRevenueProgress(decimal revenue)
    {
        var maxRevenue = GetRevenueMax();
        if (maxRevenue <= 0)
        {
            return 0;
        }
        return (double)(revenue / maxRevenue) * 100d;
    }

    private static string FormatCurrency(decimal value) => $"{value:N0} đ";
}
