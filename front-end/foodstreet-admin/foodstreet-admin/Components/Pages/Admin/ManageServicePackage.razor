@page "/admin/manage-service-package"
@layout AdminLayout
@rendermode InteractiveServer
@inject ServicePackageService PackageService
@inject ISnackbar Snackbar

<PageTitle>Goi dich vu & dang ky</PageTitle>

<MudStack Spacing="3">
    <MudStack Spacing="1">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h5">Quan ly goi dich vu & dang ky</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenNewPackage">Tao goi moi</MudButton>
        </MudStack>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Admin quan ly danh sach goi dich vu va theo doi cac dang ky goi cua seller va user tren cung mot trang.
        </MudText>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }

    <MudTabs Rounded="true" Elevation="1">
        <MudTabPanel Text="Danh sach goi">
            <MudGrid Spacing="3" Class="mt-2">
                @foreach (var package in _packages)
                {
                    <MudItem xs="12" md="6" lg="4">
                        <MudCard>
                            <MudCardContent>
                                <MudStack Spacing="1">
                                    <MudStack Row="true" Spacing="1">
                                        <MudText Typo="Typo.h6">@package.Name</MudText>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary">@package.Tier</MudChip>
                                        <MudChip T="string" Size="Size.Small" Color="@(package.Audience == "USER" ? Color.Warning : Color.Info)">@package.Audience</MudChip>
                                    </MudStack>
                                    <MudText Color="Color.Secondary">@package.Description</MudText>
                                    <MudText>Thang: @package.MonthlyPrice.ToString("N0") d</MudText>
                                    <MudText>Nam: @package.YearlyPrice.ToString("N0") d</MudText>
                                    <MudText>So gian hang toi da: @(package.Audience == "OWNER" ? package.MaxStores : 0)</MudText>
                                    <MudText>Mo audio: @(package.AllowAudioAccess ? "Co" : "Khong")</MudText>
                                    <MudDivider Class="my-2" />
                                    @foreach (var feature in package.Features)
                                    {
                                        <MudText Typo="Typo.body2">- @feature</MudText>
                                    }
                                </MudStack>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => OpenEditPackage(package))">Sua</MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => DeletePackageAsync(package))">Xoa</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="@($"Dang ky Seller ({SellerSubscriptions.Count})")">
            @if (SellerSubscriptions.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-2">
                    Chua co dang ky goi cua seller.
                </MudAlert>
            }
            else
            {
                <MudTable Items="@SellerSubscriptions" Dense="true" Hover="true" Class="mt-2">
                    <HeaderContent>
                        <MudTh>Nguoi dang ky</MudTh>
                        <MudTh>Goi</MudTh>
                        <MudTh>Chu ky</MudTh>
                        <MudTh>Gia</MudTh>
                        <MudTh>Trang thai</MudTh>
                        <MudTh>Thanh toan</MudTh>
                        <MudTh>Ngay tao</MudTh>
                        <MudTh>Kich hoat</MudTh>
                        <MudTh>Thao tac</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.SellerName<br /><small>@context.SellerEmail</small></MudTd>
                        <MudTd>@context.PackageName (@context.PackageTier)</MudTd>
                        <MudTd>@context.BillingCycle</MudTd>
                        <MudTd>@context.Price.ToString("N0") d</MudTd>
                        <MudTd>@context.Status</MudTd>
                        <MudTd>@context.PaymentStatus</MudTd>
                        <MudTd>@FormatDateTime(context.CreatedAt)</MudTd>
                        <MudTd>@FormatNullableDateTime(context.ActivatedAt)</MudTd>
                        <MudTd>
                            @if (CanCancelSubscription(context))
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => CancelSubscriptionAsync(context))">Huy</MudButton>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="@($"Dang ky User ({UserSubscriptions.Count})")">
            @if (UserSubscriptions.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-2">
                    Chua co dang ky goi cua user.
                </MudAlert>
            }
            else
            {
                <MudTable Items="@UserSubscriptions" Dense="true" Hover="true" Class="mt-2">
                    <HeaderContent>
                        <MudTh>Nguoi dang ky</MudTh>
                        <MudTh>Goi</MudTh>
                        <MudTh>Chu ky</MudTh>
                        <MudTh>Gia</MudTh>
                        <MudTh>Trang thai</MudTh>
                        <MudTh>Thanh toan</MudTh>
                        <MudTh>Ngay tao</MudTh>
                        <MudTh>Kich hoat</MudTh>
                        <MudTh>Thao tac</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.SellerName<br /><small>@context.SellerEmail</small></MudTd>
                        <MudTd>@context.PackageName (@context.PackageTier)</MudTd>
                        <MudTd>@context.BillingCycle</MudTd>
                        <MudTd>@context.Price.ToString("N0") d</MudTd>
                        <MudTd>@context.Status</MudTd>
                        <MudTd>@context.PaymentStatus</MudTd>
                        <MudTd>@FormatDateTime(context.CreatedAt)</MudTd>
                        <MudTd>@FormatNullableDateTime(context.ActivatedAt)</MudTd>
                        <MudTd>
                            @if (CanCancelSubscription(context))
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => CancelSubscriptionAsync(context))">Huy</MudButton>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>
    </MudTabs>
</MudStack>

<MudDialog @bind-Visible="_showDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingPackage == null ? "Tao goi" : "Sua goi")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_form.Name" Label="Ten goi" Class="mb-3" />
        <MudSelect @bind-Value="_form.Tier" Label="Tier" Class="mb-3">
            <MudSelectItem T="string" Value="@("Basic")">Basic</MudSelectItem>
            <MudSelectItem T="string" Value="@("Premium")">Premium</MudSelectItem>
            <MudSelectItem T="string" Value="@("VIP")">VIP</MudSelectItem>
        </MudSelect>
        <MudSelect @bind-Value="_form.Audience" Label="Audience" Class="mb-3">
            <MudSelectItem T="string" Value="@("OWNER")">OWNER</MudSelectItem>
            <MudSelectItem T="string" Value="@("USER")">USER</MudSelectItem>
        </MudSelect>
        <MudNumericField @bind-Value="_form.MonthlyPrice" Label="Gia thang" Min="0" Class="mb-3" />
        <MudNumericField @bind-Value="_form.YearlyPrice" Label="Gia nam" Min="0" Class="mb-3" />
        <MudNumericField @bind-Value="_form.MaxStores" Label="Max stores" Min="0" Class="mb-3" />
        <MudTextField @bind-Value="_form.Description" Label="Mo ta" Lines="2" Class="mb-3" />
        <MudTextField @bind-Value="_featuresText" Label="Features moi dong 1 muc" Lines="4" Class="mb-3" />
        <MudCheckBox @bind-Value="_form.AllowAudioAccess" Label="Cho phep nghe audio" />
        <MudCheckBox @bind-Value="_form.IsActive" Label="Kich hoat" />
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="@(() => _showDialog = false)">Dong</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SavePackageAsync">Luu</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _loading = true;
    private bool _showDialog;
    private List<ServicePackageModel> _packages = new();
    private List<SubscriptionModel> _subscriptions = new();
    private ServicePackageModel _form = new();
    private ServicePackageModel? _editingPackage;
    private string _featuresText = string.Empty;

    private List<SubscriptionModel> SellerSubscriptions =>
        _subscriptions.Where(x => string.Equals(x.PackageAudience, "OWNER", StringComparison.OrdinalIgnoreCase)).ToList();

    private List<SubscriptionModel> UserSubscriptions =>
        _subscriptions.Where(x => string.Equals(x.PackageAudience, "USER", StringComparison.OrdinalIgnoreCase)).ToList();

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _packages = await PackageService.GetPackagesAsync();
        _subscriptions = await PackageService.GetSubscriptionsAsync();
        _loading = false;
    }

    private void OpenNewPackage()
    {
        _editingPackage = null;
        _form = new ServicePackageModel { Audience = "OWNER", IsActive = true, MaxStores = 1 };
        _featuresText = string.Empty;
        _showDialog = true;
    }

    private void OpenEditPackage(ServicePackageModel package)
    {
        _editingPackage = package;
        _form = new ServicePackageModel
        {
            Id = package.Id,
            Name = package.Name,
            Tier = package.Tier,
            Audience = package.Audience,
            MonthlyPrice = package.MonthlyPrice,
            YearlyPrice = package.YearlyPrice,
            Description = package.Description,
            MaxStores = package.MaxStores,
            AllowAudioAccess = package.AllowAudioAccess,
            IsActive = package.IsActive,
            Features = package.Features.ToList()
        };
        _featuresText = string.Join("\n", package.Features);
        _showDialog = true;
    }

    private async Task SavePackageAsync()
    {
        _form.Features = _featuresText.Split('\n', StringSplitOptions.RemoveEmptyEntries).Select(x => x.Trim()).Where(x => !string.IsNullOrWhiteSpace(x)).ToList();
        (bool ok, string msg) result = _editingPackage == null
            ? await PackageService.CreatePackageAsync(_form)
            : await PackageService.UpdatePackageAsync(_form);

        Snackbar.Add(result.msg, result.ok ? Severity.Success : Severity.Error);
        if (result.ok)
        {
            _showDialog = false;
            await ReloadAsync();
        }
    }

    private async Task DeletePackageAsync(ServicePackageModel package)
    {
        var ok = await PackageService.DeletePackageAsync(package.Id);
        Snackbar.Add(ok ? "Da xoa goi." : "Khong the xoa goi.", ok ? Severity.Success : Severity.Error);
        if (ok)
        {
            await ReloadAsync();
        }
    }

    private async Task CancelSubscriptionAsync(SubscriptionModel subscription)
    {
        var ok = await PackageService.CancelSubscriptionAsync(subscription.Id);
        Snackbar.Add(ok ? "Da huy subscription." : "Khong the huy subscription.", ok ? Severity.Success : Severity.Error);
        if (ok)
        {
            await ReloadAsync();
        }
    }

    private static bool CanCancelSubscription(SubscriptionModel subscription) =>
        subscription.Status != "Cancelled" && subscription.Status != "Expired";

    private static string FormatDateTime(DateTime value) => value.ToLocalTime().ToString("dd/MM/yyyy HH:mm");

    private static string FormatNullableDateTime(DateTime? value) =>
        value.HasValue ? FormatDateTime(value.Value) : "-";
}

