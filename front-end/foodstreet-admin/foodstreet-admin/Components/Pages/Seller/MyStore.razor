@page "/seller/mystore"
@layout SellerLayout
@rendermode InteractiveServer
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using System.Text.Json
@inject StoreService StoreSvc
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject IConfiguration Configuration
@inject UILanguageService Lang
@implements IDisposable

<PageTitle>@Lang.T("MyStore")</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6 animate-fade-in-up">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h4" Style="font-weight:800">🏪 <span class="gradient-text-safe">@Lang.T("MyStore")</span></MudText>
        <MudText Typo="Typo.body2" Style="opacity:0.6">@Lang.T("StoreSettings")</MudText>
    </MudStack>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.AddBusiness"
               OnClick="OpenNew"
               Style="height:48px; border-radius:12px; box-shadow: 0 6px 20px rgba(99, 102, 241, 0.3)">
        @Lang.T("Add")
    </MudButton>
</MudStack>

<!-- Filters -->
<MudPaper Class="pa-6 mb-8 glass-card animate-fade-in-up delay-1" Elevation="0">
    <MudGrid AlignItems="AlignItems.Center">
        <MudItem xs="12" md="3">
            <MudTextField @bind-Value="_search" Label="@Lang.T("Search")"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" Clearable="true" />
        </MudItem>
        <MudItem xs="12" md="2">
            <MudSelect @bind-Value="_filterStatus" Label="Trạng thái" Variant="Variant.Outlined" Margin="Margin.Dense">
                <MudSelectItem Value="@("All")">Tất cả</MudSelectItem>
                <MudSelectItem Value="@("Active")">Active</MudSelectItem>
                <MudSelectItem Value="@("Pending")">Pending</MudSelectItem>
                <MudSelectItem Value="@("Rejected")">Rejected</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect @bind-Value="_filterCat" Label="Danh mục" Variant="Variant.Outlined" Margin="Margin.Dense">
                <MudSelectItem Value="@("All")">Tất cả</MudSelectItem>
                @foreach (var cat in new[]{"Ốc","Hải sản","Cơm","Bún/Phở","Đồ uống","Ăn vặt","Trà sữa","Cà phê","Quán nhậu","Lẩu/Nướng"})
                {
                    <MudSelectItem Value="@cat">@cat</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="2">
            <MudSelect @bind-Value="_sortBy" Label="Sắp xếp" Variant="Variant.Outlined" Margin="Margin.Dense">
                <MudSelectItem Value="@("Mới nhất")">Mới nhất</MudSelectItem>
                <MudSelectItem Value="@("Cũ nhất")">Cũ nhất</MudSelectItem>
                <MudSelectItem Value="@("Tên A-Z")">Tên A-Z</MudSelectItem>
                <MudSelectItem Value="@("Tên Z-A")">Tên Z-A</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="2" Class="d-flex align-center justify-end">
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Text" Icon="@Icons.Material.Filled.Countertops">
                <b>@Filtered.Count()</b> Stores
            </MudChip>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}

<!-- Cards -->
<MudGrid>
    @foreach (var store in Filtered)
    {
        <MudItem xs="12" md="6" lg="4" Class="animate-fade-in-up">
            <MudCard Elevation="0" Class="glass-card h-100 d-flex flex-column" Style="overflow:hidden">
                <div style="position:relative">
                    <MudCardMedia Image="@(string.IsNullOrEmpty(store.ImageUrl)
                        ? "https://placehold.co/400x160/e3f2fd/1565C0?text=No+Image"
                        : ResolveAudioUrl(store.ImageUrl))" Height="180" />
                    <div style="position:absolute; top:12px; left:12px">
                        <MudChip T="string" Size="Size.Small" Color="@StatusColor(store.Status)" 
                                 Style="box-shadow: 0 4px 10px rgba(0,0,0,0.1)">
                            @store.Status
                        </MudChip>
                    </div>
                </div>
                <MudCardContent Class="flex-grow-1 pa-5">
                    <MudText Typo="Typo.h6" Style="font-weight:700" Class="mb-3">@store.Name</MudText>
                    <MudStack Spacing="2">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" Style="opacity:0.5" Class="mr-2" />
                            <MudText Typo="Typo.body2" Style="font-weight:500">@store.Category</MudText>
                        </div>
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Style="opacity:0.5" Class="mr-2" />
                            <MudText Typo="Typo.body2" Style="opacity:0.7">@store.Address</MudText>
                        </div>
                        
                        @if (store.AudioUrls != null && store.AudioUrls.Any(x => !string.IsNullOrEmpty(x.Value)))
                        {
                            <MudPaper Class="pa-3 mt-4" Elevation="0" Style="background: rgba(99,102,241,0.05); border-radius:12px">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
                                    <MudIcon Icon="@Icons.Material.Filled.RecordVoiceOver" Size="Size.Small" Color="Color.Primary" />
                                    <MudText Typo="Typo.caption" Color="Color.Primary" Style="font-weight:700">Audio Guide</MudText>
                                </MudStack>
                                @foreach (var aud in store.AudioUrls.Where(x => !string.IsNullOrEmpty(x.Value)))
                                {
                                    <div class="d-flex align-center mt-1">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Style="min-width: 80px; font-weight: bold; padding: 0;">
                                            @GetLangDisplayName(aud.Key)
                                        </MudChip>
                                        <audio @key="@($"audio-{store.Id}-{aud.Key}-{aud.Value}")" 
                                               src="@ResolveAudioUrl(aud.Value)" 
                                               controls preload="none" 
                                               style="width: 100%; height: 32px; filter: grayscale(1) opacity(0.8)">
                                        </audio>
                                    </div>
                                }
                            </MudPaper>
                        }
                    </MudStack>
                </MudCardContent>
                <MudCardActions Class="pa-4 pt-0">
                    <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Text"
                               StartIcon="@Icons.Material.Filled.Edit" OnClick="@(() => OpenEdit(store))">
                        @Lang.T("Edit")
                    </MudButton>
                    <MudButton Size="Size.Small" Color="Color.Info" Variant="Variant.Text"
                               StartIcon="@Icons.Material.Filled.Analytics"
                               Href="@($"/seller/stats/{store.Id}")">Stats</MudButton>
                    <MudSpacer />
                    <!-- QR Code buttons -->
                    <MudTooltip Text="Xem mã QR">
                        <MudIconButton Icon="@Icons.Material.Filled.QrCode2"
                                       Color="Color.Warning"
                                       Size="Size.Small"
                                       OnClick="@(() => OpenQrModal(store))" />
                    </MudTooltip>
                    <MudTooltip Text="Tải mã QR (PNG)">
                        <MudIconButton Icon="@Icons.Material.Filled.Download"
                                       Color="Color.Success"
                                       Size="Size.Small"
                                       OnClick="@(() => DownloadQrCode(store))" />
                    </MudTooltip>
                    <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error"
                                   Size="Size.Small" OnClick="@(() => DeleteStore(store))" />
                </MudCardActions>
            </MudCard>
        </MudItem>
    }
    @if (!Filtered.Any() && !_loading)
    {
        <MudItem xs="12">
            <MudPaper Class="pa-8 text-center" Elevation="0" Style="border:2px dashed #e0e0e0;border-radius:12px">
                <MudIcon Icon="@Icons.Material.Filled.Storefront" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">
                    Chưa có gian hàng nào
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3"
                           StartIcon="@Icons.Material.Filled.AddBusiness" OnClick="OpenNew">
                    @Lang.T("Add")
                </MudButton>
            </MudPaper>
        </MudItem>
    }
</MudGrid>

<!-- Dialog -->
<MudDialog @bind-Visible="_showDialog" Options="@(new DialogOptions{MaxWidth=MaxWidth.Medium,FullWidth=true})">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AddBusiness" Class="mr-2" />
            @(_editing == null ? Lang.T("Add") : Lang.T("Edit"))
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_form.Name" Label="@Lang.T("StoreName")" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_form.Phone" Label="Số điện thoại" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.Address" Label="@Lang.T("Location")" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect @bind-Value="_form.Category" Label="@Lang.T("Category")" Variant="Variant.Outlined">
                    @foreach (var cat in new[]{"Ốc","Hải sản","Cơm","Bún/Phở","Đồ uống","Ăn vặt","Trà sữa","Cà phê","Quán nhậu","Lẩu/Nướng"})
                    { <MudSelectItem Value="@cat">@cat</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudTextField @bind-Value="_form.Latitude" Label="Vĩ độ (GPS)" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudTextField @bind-Value="_form.Longitude" Label="Kinh độ (GPS)" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12">
                        <div id="pickerMap" style="height: 200px; width: 100%; border-radius: 8px; margin-bottom: 8px; z-index: 1;"></div>
                        <MudButton StartIcon="@Icons.Material.Filled.MyLocation" Color="Color.Info" Variant="Variant.Text" OnClick="GetMyLocation">
                            Lấy vị trí thiết bị hiện tại
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.Description" Label="@Lang.T("Description")"
                              Variant="Variant.Outlined" Lines="3" />
            </MudItem>
            <!-- Upload zones -->
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Ảnh đại diện</MudText>
                <label for="profileUpload" style="display: block;">
                    <div class="d-flex flex-column align-center border-dashed pa-4" style="border: 2px dashed #ccc; border-radius: 8px; cursor: pointer; position: relative;">
                        @if (!string.IsNullOrEmpty(_form.ImageUrl))
                        {
                            <MudImage Src="@(ResolveAudioUrl(_form.ImageUrl))" Height="120" Style="object-fit: cover; width: 100%; border-radius: 4px;" />
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" Style="position: absolute; top: 5px; right: 5px; background: rgba(255,255,255,0.7)" />
                        }
                        else
                        {
                            @if (_isUploadingProfile)
                            {
                                <MudProgressCircular Indeterminate="true" Size="Size.Medium" Color="Color.Primary" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.AddPhotoAlternate" Size="Size.Large" Color="Color.Primary" />
                                <MudText Typo="Typo.caption" Class="mt-1">Chọn ảnh JPG/PNG (Max 5MB)</MudText>
                            }
                        }
                    </div>
                </label>
                <InputFile id="profileUpload" OnChange="HandleProfileUpload" hidden accept=".jpg,.jpeg,.png" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Ảnh menu (nhiều ảnh)</MudText>
                <label for="menuUpload" style="display: block;">
                    <div class="d-flex flex-column align-center border-dashed pa-4" style="border: 2px dashed #ccc; border-radius: 8px; cursor: pointer;">
                        @if (_isUploadingMenu)
                        {
                            <MudProgressCircular Indeterminate="true" Size="Size.Medium" Color="Color.Secondary" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Collections" Size="Size.Large" Color="Color.Secondary" />
                            <MudText Typo="Typo.caption" Class="mt-1">Chọn nhiều ảnh menu</MudText>
                        }
                    </div>
                </label>
                <InputFile id="menuUpload" OnChange="HandleMenuUpload" multiple hidden accept=".jpg,.jpeg,.png" />
            </MudItem>

            @if (!string.IsNullOrEmpty(_form.MenuImagesUrl))
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Class="mb-1">Danh sách ảnh menu:</MudText>
                    <MudStack Row="true" Spacing="2" Class="overflow-x-auto pb-2">
                        @foreach (var url in _form.MenuImagesUrl.Split(',', StringSplitOptions.RemoveEmptyEntries))
                        {
                            <div style="position: relative; flex-shrink: 0;">
                                <MudImage Src="@(ResolveAudioUrl(url))" Height="80" Width="80" Style="object-fit: cover; border-radius: 4px;" />
                                <MudIconButton Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Color="Color.Error" 
                                               Style="position: absolute; top: -5px; right: -5px; padding: 2px; background: white;"
                                               OnClick="@(() => RemoveMenuImage(url))" />
                            </div>
                        }
                    </MudStack>
                </MudItem>
            }

            <MudItem xs="12">
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle2" Class="mb-3" Style="font-weight:600">
                    <MudIcon Icon="@Icons.Material.Filled.RecordVoiceOver" Size="Size.Small" Class="mr-1" />
                    Giọng thuyết minh (TTS)
                </MudText>

                @if (_editing == null)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-2">
                        Sau khi đăng ký gian hàng, bạn có thể tạo giọng thuyết minh tự động.
                    </MudAlert>
                }
                else
                {
                    <MudTextField @bind-Value="_form.Description" Label="Nội dung thuyết minh (TTS)"
                                  Variant="Variant.Outlined" Lines="3" Class="mb-3"
                                  HelperText="Nội dung này sẽ được chuyển thành giọng nói. Hệ thống tự động dịch sang ngôn ngữ bạn chọn." />

                    @* ── Language Chips ── *@
                    <MudText Typo="Typo.caption" Class="mb-2" Style="opacity:0.7">Chọn ngôn ngữ cần tạo:</MudText>
                    <MudStack Row="true" Spacing="2" Class="mb-3" AlignItems="AlignItems.Center">
                        @foreach (var lang in _supportedLangs)
                        {
                            var isSelected = _selectedTtsLang == lang.Code;
                            <MudChip T="string" 
                                     Color="@(isSelected ? Color.Primary : Color.Default)" 
                                     Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                                     OnClick="@(() => SelectLang(lang.Code))"
                                     Icon="@(isSelected ? Icons.Material.Filled.RadioButtonChecked : Icons.Material.Filled.RadioButtonUnchecked)"
                                     Style="@(isSelected ? "font-weight:700" : "")">
                                @lang.Name
                            </MudChip>
                        }
                        
                        @if (_selectedTtsLang != "vi")
                        {
                            <MudButton Variant="Variant.Filled" 
                                       Color="Color.Info" 
                                       Size="Size.Medium" 
                                       StartIcon="@Icons.Material.Filled.Translate"
                                       OnClick="TranslateCurrentText"
                                       Disabled="@(_translating || string.IsNullOrWhiteSpace(_form.Description))"
                                       Class="ml-4 px-6 animate__animated animate__fadeIn"
                                       Elevation="4"
                                       Style="border-radius:30px; text-transform:none; background: linear-gradient(90deg, #0ea5e9 0%, #38bdf8 100%);">
                                @if (_translating)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <span>Đang dịch...</span>
                                }
                                else
                                {
                                    <span>Dịch ngay</span>
                                }
                            </MudButton>
                        }
                    </MudStack>

                    @* ── Action Buttons ── *@
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.VolumeUp"
                                   OnClick="GenerateTTS" 
                                   Disabled="@(_generatingTts || _generatingTtsAll || string.IsNullOrWhiteSpace(_form.Description))"
                                   Style="border-radius:10px; text-transform:none">
                            @if (_generatingTts) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                            Tạo thuyết minh (@GetLangDisplayName(_selectedTtsLang))
                        </MudButton>

                        <MudButton Variant="Variant.Outlined" Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.Translate"
                                   OnClick="GenerateTTSAll" 
                                   Disabled="@(_generatingTts || _generatingTtsAll || string.IsNullOrWhiteSpace(_form.Description))"
                                   Style="border-radius:10px; text-transform:none">
                            @if (_generatingTtsAll) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                            🌐 Tạo cả 3 ngôn ngữ
                        </MudButton>

                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="ResetTtsText">Đặt lại</MudButton>
                    </MudStack>

                    @if (_generatingTtsAll)
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                <MudText Typo="Typo.caption">
                                    Đang tạo audio cho 3 ngôn ngữ... Quá trình này có thể mất 1-3 phút.
                                </MudText>
                            </MudStack>
                        </MudAlert>
                    }
                    else if (!string.IsNullOrWhiteSpace(_ttsAllLastStatus))
                    {
                        <MudAlert Severity="@_ttsAllLastSeverity" Variant="Variant.Outlined" Dense="true" Class="mb-2">
                            @_ttsAllLastStatus
                        </MudAlert>
                    }

                    @if (!string.IsNullOrEmpty(_form.AudioUrl))
                    {
                        <MudPaper Class="pa-3 mt-1" Elevation="0" Style="background:rgba(76,175,80,0.08);border-radius:10px;border:1px solid rgba(76,175,80,0.2)">
                            <MudText Typo="Typo.caption" Color="Color.Success" Class="d-flex align-center mb-1">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-1" />
                                Audio thuyết minh đã sẵn sàng:
                            </MudText>
                            <audio @key="@($"dialog-audio-{_form.Id}-{_form.AudioUrl}")" 
                                   src="@ResolveAudioUrl(_form.AudioUrl)" 
                                   controls preload="auto" 
                                   style="width: 100%; height: 36px;">
                                Trình duyệt không hỗ trợ audio.
                            </audio>
                        </MudPaper>
                }
            }
        </MudItem>
    </MudGrid>
</DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog" Variant="Variant.Outlined" Style="border-radius:12px">@Lang.T("Cancel")</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="SaveStore" Disabled="_saving"
                   Style="border-radius:12px; box-shadow: 0 6px 20px rgba(99, 102, 241, 0.3)">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            @Lang.T("Save")
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- QR Code Modal                                               -->
<!-- ═══════════════════════════════════════════════════════════ -->
<MudDialog @bind-Visible="_showQrDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseButton = true })">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.QrCode2" Color="Color.Warning" />
            <MudText Typo="Typo.h6" Style="font-weight:700">Mã QR Gian hàng</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_qrStore != null)
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="3">
                <MudText Typo="Typo.subtitle1" Style="font-weight:600; text-align:center">@_qrStore.Name</MudText>

                @if (!string.IsNullOrEmpty(_qrStore.QrCodeUrl))
                {
                    <!-- QR Code image -->
                    <div style="padding: 16px; background: white; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.12); display:inline-block;">
                        <img src="@ResolveAudioUrl(_qrStore.QrCodeUrl)"
                             alt="QR Code @_qrStore.Name"
                             style="width:240px; height:240px; display:block; image-rendering: pixelated;" />
                    </div>

                    <!-- Encoded URL info -->
                    <MudPaper Elevation="0" Class="pa-3 w-100" Style="background:rgba(255,107,53,0.06); border:1px solid rgba(255,107,53,0.2); border-radius:10px;">
                        <MudText Typo="Typo.caption" Style="opacity:0.6; display:block; margin-bottom:4px;">URL được mã hóa:</MudText>
                        <MudText Typo="Typo.body2" Style="font-family:monospace; word-break:break-all; color:#FF6B35; font-weight:600;">
                            @_qrEncodedUrl
                        </MudText>
                    </MudPaper>

                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                        Khách hàng quét mã QR này để xem thông tin và nghe thuyết minh gian hàng.
                    </MudAlert>
                }
                else
                {
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.QrCodeScanner" Style="font-size:80px; opacity:0.3;" />
                        <MudText Typo="Typo.body2" Style="opacity:0.6">Chưa có mã QR. Đang tạo...</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="OnRegenerateQrClick"
                                   Disabled="@_generatingQr">
                            @if (_generatingQr) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                            Tạo mã QR
                        </MudButton>
                    </MudStack>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Warning" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="OnRegenerateQrClick" Disabled="@_generatingQr" Style="@_qrBtnStyle">
            @if (_generatingQr) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Tạo lại
        </MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Download" OnClick="OnDownloadQrClick" Style="@_qrBtnStyle">Tải PNG</MudButton>
        <MudButton OnClick="@(() => _showQrDialog = false)" Variant="Variant.Outlined" Style="border-radius:10px">Đóng</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _loading = true, _showDialog, _saving, _translating;
    private bool _showQrDialog, _generatingQr;           // QR modal state
    private StoreModel? _qrStore;                         // Store currently shown in QR modal

    // Computed style for QR action buttons: visible only when QR URL exists
    private string _qrBtnStyle => (_qrStore != null && !string.IsNullOrEmpty(_qrStore.QrCodeUrl))
        ? "border-radius:10px"
        : "display:none";

    // Computed URL shown in QR modal
    private string _qrEncodedUrl => _qrStore != null
        ? $"{Configuration["App:BaseUrl"] ?? "http://localhost:5042"}/poi/{_qrStore.Id}"
        : "";

    private string _search = "", _filterStatus = "All", _filterCat = "All", _sortBy = "Mới nhất";
    private List<StoreModel> _stores = new();
    private StoreModel? _editing;
    private StoreModel _form = new();
    private int CurrentSellerId;
    private string _viDescription = "";

    private string _selectedTtsLang = "vi";
    private List<(string Code, string Name)> _supportedLangs = new()
    {
        ("vi", "Tiếng Việt 🇻🇳"),
        ("en", "English 🇺🇸"),
        ("zh", "Chinese 🇨🇳")
    };

    private IEnumerable<StoreModel> Filtered
    {
        get
        {
            var query = _stores.Where(s =>
                (string.IsNullOrEmpty(_search) || s.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
                (_filterStatus == "All" || s.Status == _filterStatus) &&
                (_filterCat == "All" || s.Category == _filterCat));

            return _sortBy switch
            {
                "Cũ nhất" => query.OrderBy(s => s.Id),
                "Tên A-Z" => query.OrderBy(s => s.Name),
                "Tên Z-A" => query.OrderByDescending(s => s.Name),
                _ => query.OrderByDescending(s => s.Id),
            };
        }
    }

    private Color StatusColor(string s) => s switch
    { "Active" => Color.Success, "Pending" => Color.Warning, _ => Color.Error };

    protected override async Task OnInitializedAsync()
    {
        Lang.OnLanguageChanged += HandleLanguageChanged;
        await LoadData();
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(async () => {
            await LoadData();
            StateHasChanged();
        });
    }

    private async Task LoadData()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            var idClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (idClaim != null && int.TryParse(idClaim.Value, out int id))
            {
                CurrentSellerId = id;
            }
        }
        _stores = await StoreSvc.GetStoresAsync(CurrentSellerId);
        _loading = false;
    }

    private async Task DeleteStore(StoreModel s)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Xác nhận xóa", 
            $"Bạn có chắc chắn muốn xóa gian hàng '{s.Name}' không?", 
            yesText: "Xóa", cancelText: "Hủy");

        if (result == true)
        {
            var ok = await StoreSvc.DeleteStoreAsync(s.Id);
            if (ok) { _stores.Remove(s); Snackbar.Add("Đã xóa gian hàng!", Severity.Success); }
            else { Snackbar.Add("Lỗi khi xóa gian hàng!", Severity.Error); }
        }
    }

    private DotNetObjectReference<MyStore>? _objRef;

    private async Task InitMapAsync()
    {
        try
        {
            _objRef ??= DotNetObjectReference.Create(this);
            // Delay to let the MudDialog animation finish rendering the #pickerMap div
            await Task.Delay(400);
            await JS.InvokeVoidAsync("leafletInterop.initPickerMap", "pickerMap", _form.Latitude, _form.Longitude, _objRef);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error initializing map: {ex.Message}");
        }
    }

    [JSInvokable]
    public void OnLocationChanged(double lat, double lng)
    {
        _form.Latitude = lat;
        _form.Longitude = lng;
        InvokeAsync(StateHasChanged);
    }

    private async Task GetMyLocation()
    {
        if (_objRef != null)
            await JS.InvokeVoidAsync("leafletInterop.getCurrentLocation", _objRef);
    }

    private void OpenNew() 
    { 
        _editing = null; 
        _selectedTtsLang = "vi";
        _viDescription = "";
        _form = new() { SellerId = CurrentSellerId, Latitude = 10.762622, Longitude = 106.660172 }; 
        _showDialog = true; 
        _ = InitMapAsync();
    }

    private void OpenEdit(StoreModel s) 
    { 
        _editing = s; 
        _selectedTtsLang = "vi";
        _viDescription = s.Description ?? "";
        _form = new StoreModel { 
            Id=s.Id, Name=s.Name, Phone=s.Phone, Address=s.Address, 
            Category=s.Category, Description=s.Description, 
            Latitude=s.Latitude, Longitude=s.Longitude, 
            SellerId=s.SellerId, AudioUrl=s.AudioUrl, 
            ImageUrl=s.ImageUrl, MenuImagesUrl=s.MenuImagesUrl,
            AudioUrls = s.AudioUrls != null ? new Dictionary<string, string>(s.AudioUrls) : new Dictionary<string, string>()
        }; 
        _showDialog = true; 
        _ = InitMapAsync();
    }

    private async Task SaveStore()
    {
        // Cập nhật _viDescription nếu người dùng lưu khi đang ở tab tiếng Việt
        if (_selectedTtsLang == "vi")
        {
            _viDescription = _form.Description ?? "";
        }

        if (string.IsNullOrWhiteSpace(_form.Name)) return;
        _saving = true;

        // BẢO VỆ DỮ LIỆU: Luôn gửi bản gốc Tiếng Việt lên DB để làm mô tả chính của Shop
        var currentDisplayDesc = _form.Description;
        _form.Description = _viDescription;

        try
        {
            if (_editing == null)
            {
                var (ok, msg) = await StoreSvc.CreateStoreAsync(_form);
                Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
                if (ok) 
                {
                    _stores = await StoreSvc.GetStoresAsync(CurrentSellerId);
                    // Auto-switch to edit mode for the newly created shop so user can generate TTS
                    var newShop = _stores.OrderByDescending(s => s.Id).FirstOrDefault();
                    if (newShop != null)
                    {
                        _editing = newShop;
                        _form.Id = newShop.Id;
                        _form.AudioUrl = newShop.AudioUrl;
                        Snackbar.Add("Bạn có thể tạo giọng thuyết minh ngay bây giờ!", Severity.Info);
                    }
                }
            }
            else
            {
                var (ok, msg) = await StoreSvc.UpdateStoreAsync(_form);
                Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
                if (ok) _stores = await StoreSvc.GetStoresAsync(CurrentSellerId);
            }
        }
        finally
        {
            // Trả lại text hiển thị trên UI theo tab đang mở
            _form.Description = currentDisplayDesc;
            _saving = false;
        }
    }

    private bool _generatingTts, _generatingTtsAll, _isUploadingProfile, _isUploadingMenu;
    private string _ttsAllLastStatus = "";
    private Severity _ttsAllLastSeverity = Severity.Info;

    private async Task HandleProfileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        _isUploadingProfile = true;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024); // 5MB
            var result = await StoreSvc.UploadMediaAsync(stream, file.Name);
            if (!string.IsNullOrEmpty(result))
            {
                _form.ImageUrl = result;
                Snackbar.Add("Tải ảnh đại diện thành công!", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải ảnh: {ex.Message}", Severity.Error);
        }
        finally { _isUploadingProfile = false; }
    }

    private async Task HandleMenuUpload(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles(maximumFileCount: 10);
        if (!files.Any()) return;
        _isUploadingMenu = true;
        try
        {
            var uploadTasks = files.Select(async f => {
                using var s = f.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
                return await StoreSvc.UploadMediaAsync(s, f.Name);
            });
            var results = await Task.WhenAll(uploadTasks);
            var successfulUrls = results.Where(r => !string.IsNullOrEmpty(r)).Select(r => r!).ToList();
            
            if (successfulUrls.Any())
            {
                var currentImages = string.IsNullOrEmpty(_form.MenuImagesUrl) 
                    ? new List<string>() 
                    : _form.MenuImagesUrl.Split(',').ToList();
                currentImages.AddRange(successfulUrls);
                _form.MenuImagesUrl = string.Join(",", currentImages);
                Snackbar.Add($"Đã tải lên {successfulUrls.Count} ảnh menu!", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải ảnh menu: {ex.Message}", Severity.Error);
        }
        finally { _isUploadingMenu = false; }
    }

    private void RemoveMenuImage(string url)
    {
        var images = _form.MenuImagesUrl?.Split(',').ToList() ?? new();
        images.Remove(url);
        _form.MenuImagesUrl = string.Join(",", images);
    }

    private void ResetTtsText()
    {
        _form.Description = $"{_form.Name}. {_form.Phone}";
        if (_selectedTtsLang == "vi")
        {
            _viDescription = _form.Description;
        }
    }

    private async Task SelectLang(string code)
    {
        if (_selectedTtsLang == code) return;
        
        // Lưu lại nội dung Tiếng Việt trước khi chuyển đi (nếu đang ở tab vi)
        if (_selectedTtsLang == "vi")
        {
            _viDescription = _form.Description ?? "";
        }
        
        _selectedTtsLang = code;
        
        // Cập nhật audio player trong dialog theo ngôn ngữ đang chọn
        if (_editing != null && _editing.AudioUrls != null && _editing.AudioUrls.TryGetValue(code, out var existingAudio))
        {
            _form.AudioUrl = existingAudio;
        }
        else if (code == "vi" && _editing != null && !string.IsNullOrEmpty(_editing.AudioUrl) && _editing.AudioUrls?.ContainsKey("vi") != true)
        {
            // Fallback cho bản cũ nếu chưa có trong AudioUrls
            _form.AudioUrl = _editing.AudioUrl;
        }
        else
        {
            _form.AudioUrl = "";
        }
        
        // Khôi phục văn bản
        if (code == "vi")
        {
            _form.Description = _viDescription;
            StateHasChanged(); // Ép UI vẽ lại nội dung Tiếng Việt gốc
        }
        else
        {
            // Tự động dịch từ Tiếng Việt (gốc) sang ngôn ngữ mới
            await TranslateCurrentText();
        }
    }

    private async Task TranslateCurrentText()
    {
        var textToTranslate = _selectedTtsLang == "vi" ? _form.Description : _viDescription;
        if (string.IsNullOrWhiteSpace(textToTranslate) || _selectedTtsLang == "vi") return;
        
        _translating = true;
        try
        {
            var translated = await StoreSvc.TranslateTextAsync(textToTranslate, _selectedTtsLang);
            if (!string.IsNullOrEmpty(translated))
            {
                _form.Description = translated;
                Snackbar.Add($"Đã dịch sang {GetLangDisplayName(_selectedTtsLang)}!", Severity.Info);
                
                // Tự động tạo audio thuyết minh sau khi dịch (nếu cửa hàng đã được lưu)
                if (_editing != null)
                {
                    await GenerateTTS();
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi dịch thuật: {ex.Message}", Severity.Error);
        }
        finally
        {
            _translating = false;
            // Ép UI cập nhật để MudTextField nhận chuỗi mới ngay lập tức
            StateHasChanged(); 
        }
    }

    private string GetLangDisplayName(string code) => code switch
    {
        "vi" => "Tiếng Việt",
        "en" => "English",
        "zh" => "中文",
        _ => code.ToUpper()
    };

    private async Task GenerateTTS()
    {
        if (_editing == null || string.IsNullOrWhiteSpace(_form.Description)) return;
        _generatingTts = true;
        
        // Gửi văn bản mô tả hiện tại và mã ngôn ngữ đã chọn lên để sinh audio
        var result = await StoreSvc.GenerateTTSWithTextAsync(_editing.Id, _form.Description, _selectedTtsLang);
        
        if (result.ValueKind != JsonValueKind.Undefined && result.TryGetProperty("audioUrl", out var audioUrlProp))
        {
            var audioUrl = audioUrlProp.GetString() ?? "";
            _form.AudioUrl = audioUrl;
            _editing.AudioUrl = audioUrl;
            if (_editing.AudioUrls == null) _editing.AudioUrls = new Dictionary<string, string>();
            _editing.AudioUrls[_selectedTtsLang] = audioUrl;

            // Cập nhật text đã dịch vào Form để Seller thấy
            if (result.TryGetProperty("description", out var descProp))
            {
                _form.Description = descProp.GetString() ?? _form.Description;
                _editing.Description = _form.Description;
            }
            if (result.TryGetProperty("name", out var nameProp))
            {
                _form.Name = nameProp.GetString() ?? _form.Name;
                _editing.Name = _form.Name;
            }

            Snackbar.Add($"Đã dịch và tạo giọng nói ({_selectedTtsLang.ToUpper()}) thành công!", Severity.Success);
            _stores = await StoreSvc.GetStoresAsync(CurrentSellerId);
        }
        else
        {
            Snackbar.Add("Lỗi khi tạo TTS hoặc dịch thuật. Vui lòng kiểm tra lại cấu hình Azure.", Severity.Error);
        }
        _generatingTts = false;
    }

    private async Task GenerateTTSAll()
    {
        if (_editing == null || string.IsNullOrWhiteSpace(_form.Description)) return;
        _generatingTtsAll = true;
        _ttsAllLastStatus = "";
        _ttsAllLastSeverity = Severity.Info;
        StateHasChanged();
        
        try
        {
            // Always send the original Vietnamese text to backend (Azure Translator is configured from=vi).
            var viText = string.IsNullOrWhiteSpace(_viDescription) ? _form.Description : _viDescription;
            var result = await StoreSvc.GenerateTTSAllLanguagesAsync(_editing.Id, viText);
            
            if (result.ValueKind != JsonValueKind.Undefined && result.TryGetProperty("results", out var resultsProp))
            {
                int successCount = 0;
                int failCount = 0;
                var details = new List<string>();
                
                if (_editing.AudioUrls == null) _editing.AudioUrls = new Dictionary<string, string>();
                foreach (var item in resultsProp.EnumerateArray())
                {
                    var success = item.TryGetProperty("success", out var successPropItem) && successPropItem.GetBoolean();
                    var langName = item.TryGetProperty("languageName", out var langNameProp) ? langNameProp.GetString() : "";
                    var langCode = item.TryGetProperty("language", out var langCodeProp) ? langCodeProp.GetString() : "";
                    
                    if (success)
                    {
                        successCount++;
                        details.Add($"✅ {langName}");
                        if (item.TryGetProperty("audioUrl", out var audioUrlProp))
                        {
                            var aUrl = audioUrlProp.GetString();
                            if (!string.IsNullOrEmpty(aUrl) && !string.IsNullOrEmpty(langCode))
                            {
                                _editing.AudioUrls[langCode] = aUrl;
                            }
                        }
                    }
                    else
                    {
                        failCount++;
                        details.Add($"❌ {langName}");
                    }
                }

                // Update current form with Vietnamese audio URL
                var viResult = resultsProp.EnumerateArray()
                    .FirstOrDefault(x => x.TryGetProperty("language", out var lp) && lp.GetString() == "vi");
                if (viResult.ValueKind != JsonValueKind.Undefined && viResult.TryGetProperty("audioUrl", out var viAudioProp))
                {
                    _form.AudioUrl = viAudioProp.GetString();
                    _editing.AudioUrl = _form.AudioUrl;
                }

                _stores = await StoreSvc.GetStoresAsync(CurrentSellerId);
                
                // Show a SINGLE summary snackbar instead of one per language
                var summaryMsg = failCount == 0
                    ? $"🎉 Đã tạo thuyết minh cho cả {successCount} ngôn ngữ thành công! ({string.Join(", ", details)})"
                    : $"Kết quả: {successCount} thành công, {failCount} thất bại ({string.Join(", ", details)})";
                
                Snackbar.Add(summaryMsg, failCount == 0 ? Severity.Success : Severity.Warning);
                _ttsAllLastStatus = summaryMsg;
                _ttsAllLastSeverity = failCount == 0 ? Severity.Success : Severity.Warning;
            }
            else
            {
                const string message = "Lỗi khi tạo TTS đa ngôn ngữ. Vui lòng kiểm tra lại cấu hình Azure.";
                Snackbar.Add(message, Severity.Error);
                _ttsAllLastStatus = message;
                _ttsAllLastSeverity = Severity.Error;
            }
        }
        catch (Exception ex)
        {
            var message = $"Lỗi: {ex.Message}";
            Snackbar.Add(message, Severity.Error);
            _ttsAllLastStatus = message;
            _ttsAllLastSeverity = Severity.Error;
        }
        
        _generatingTtsAll = false;
        StateHasChanged();
    }

    private void CloseDialog() { _showDialog = false; }

    // ── QR Code Methods ────────────────────────────────────────────────────────

    private void OpenQrModal(StoreModel store)
    {
        _qrStore = store;
        _showQrDialog = true;
    }

    private async Task OnRegenerateQrClick() 
    { 
        if (_qrStore != null) await RegenerateQrCode(_qrStore); 
    }

    private async Task OnDownloadQrClick() 
    { 
        if (_qrStore != null) await DownloadQrCode(_qrStore); 
    }

    private async Task DownloadQrCode(StoreModel store)
    {
        if (string.IsNullOrEmpty(store.QrCodeUrl))
        {
            Snackbar.Add("Gian hàng chưa có mã QR", Severity.Warning);
            return;
        }

        var fullUrl = ResolveAudioUrl(store.QrCodeUrl);
        var fileName = $"qr-{store.Name.Replace(" ", "-").ToLowerInvariant()}.png";

        try
        {
            await JS.InvokeVoidAsync("downloadFileFromUrl", fullUrl, fileName);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải xuống: {ex.Message}", Severity.Error);
        }
    }

    private async Task RegenerateQrCode(StoreModel store)
    {
        _generatingQr = true;
        StateHasChanged();
        try
        {
            var ok = await StoreSvc.RegenerateQrCodeAsync(store.Id);
            if (ok != null)
            {
                store.QrCodeUrl = ok;
                if (_qrStore?.Id == store.Id) _qrStore.QrCodeUrl = ok;

                // Update in main list too
                var idx = _stores.FindIndex(s => s.Id == store.Id);
                if (idx >= 0) _stores[idx].QrCodeUrl = ok;

                Snackbar.Add("Đã tạo lại mã QR thành công!", Severity.Success);
            }
            else
            {
                Snackbar.Add("Lỗi khi tạo mã QR!", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
        finally
        {
            _generatingQr = false;
            StateHasChanged();
        }
    }

    private string ResolveAudioUrl(string? url)
    {
        if (string.IsNullOrEmpty(url)) return "";
        if (url.StartsWith("http", StringComparison.OrdinalIgnoreCase)) return url;
        
        var apiBase = Configuration["ApiBaseUrl"] ?? "http://localhost:5279/api/";
        var backendBase = apiBase.Replace("/api/", "", StringComparison.OrdinalIgnoreCase).TrimEnd('/');
        
        // Ensure url starts with /
        var normalizedUrl = url.StartsWith("/") ? url : "/" + url;
        return $"{backendBase}{normalizedUrl}";
    }

    public void Dispose()
    {
        Lang.OnLanguageChanged -= HandleLanguageChanged;
        _objRef?.Dispose();
    }
}
