@page "/seller/dashboard"
@layout SellerLayout
@rendermode InteractiveServer
@inject StoreService StoreSvc
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState
@inject UILanguageService Lang
@implements IDisposable

<PageTitle>@Lang.T("Dashboard")</PageTitle>

<MudText Typo="Typo.h5" Style="font-weight:700" Class="mb-1">📊 @Lang.T("Dashboard")</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-5">
    @Lang.T("StoreSettings")
</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}

<!-- Stats Cards -->
<MudGrid>
    <MudItem xs="12" sm="6" md="3" Class="animate-fade-in-up">
        <MudPaper Class="pa-5 glass-card" Elevation="0">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                <div class="gradient-icon" style="background: var(--primary-gradient)">
                    <MudIcon Icon="@Icons.Material.Filled.Headphones" Size="Size.Medium" />
                </div>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h4" Style="font-weight:800">@_totalListens.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Style="text-transform:uppercase; letter-spacing:1px; font-weight:600; opacity:0.6">Audio Listens</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3" Class="animate-fade-in-up delay-1">
        <MudPaper Class="pa-5 glass-card" Elevation="0">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                <div class="gradient-icon" style="background: var(--accent-gradient)">
                    <MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Medium" />
                </div>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h4" Style="font-weight:800">@_totalViews.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Style="text-transform:uppercase; letter-spacing:1px; font-weight:600; opacity:0.6">Store Views</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3" Class="animate-fade-in-up delay-2">
        <MudPaper Class="pa-5 glass-card" Elevation="0">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                <div class="gradient-icon" style="background: var(--secondary-gradient)">
                    <MudIcon Icon="@Icons.Material.Filled.StarRate" Size="Size.Medium" />
                </div>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h4" Style="font-weight:800">@_totalReviews.ToString()</MudText>
                    <MudText Typo="Typo.caption" Style="text-transform:uppercase; letter-spacing:1px; font-weight:600; opacity:0.6">Reviews</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3" Class="animate-fade-in-up delay-3">
        <MudPaper Class="pa-5 glass-card" Elevation="0">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                <div class="gradient-icon" style="background: var(--primary-gradient); filter: hue-rotate(45deg)">
                    <MudIcon Icon="@Icons.Material.Filled.Store" Size="Size.Medium" />
                </div>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h4" Style="font-weight:800">@_activeCount.ToString()</MudText>
                    <MudText Typo="Typo.caption" Style="text-transform:uppercase; letter-spacing:1px; font-weight:600; opacity:0.6">Active Stores</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudGrid Class="mt-4">
    <!-- Monthly Stats -->
    <MudItem xs="12" md="8" Class="animate-fade-in-up delay-4">
        <MudPaper Class="pa-6 glass-card" Elevation="0">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6">
                <MudText Typo="Typo.h6" Style="font-weight:700">📈 @Lang.T("MonthlyStats")</MudText>
                <MudSpacer />
                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.PictureAsPdf" Class="mr-2"
                           Style="box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2)">PDF</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.TableChart"
                           Style="box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2)">Excel</MudButton>
            </MudStack>
            <MudTable Items="@_stats" Hover="true" Dense="false" Class="mud-table-glass">
                <HeaderContent>
                    <MudTh>@Lang.T("Month")</MudTh>
                    <MudTh>@Lang.T("Listens")</MudTh>
                    <MudTh>@Lang.T("Views")</MudTh>
                    <MudTh>@Lang.T("Reviews")</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Month">@context.Month.ToString()</MudTd>
                    <MudTd DataLabel="Listens">
                        <MudText Style="font-weight:600">@context.TotalListens.ToString()</MudText>
                    </MudTd>
                    <MudTd DataLabel="Views">
                        <MudText Color="Color.Primary" Style="font-weight:600">@context.TotalViews.ToString()</MudText>
                    </MudTd>
                    <MudTd DataLabel="Reviews">
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">@context.TotalReviews.ToString()</MudChip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </MudItem>

    <!-- Quick Actions + Stores -->
    <MudItem xs="12" md="4">
        <MudStack Spacing="4">
            <MudPaper Class="pa-6 glass-card animate-fade-in-up delay-4" Elevation="0">
                <MudText Typo="Typo.subtitle1" Style="font-weight:700" Class="mb-4">⚡ Quick Actions</MudText>
                <MudStack Spacing="3">
                    <MudButton Href="/seller/mystore" Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Store" FullWidth="true"
                               Style="height:48px; box-shadow: 0 6px 15px rgba(99, 102, 241, 0.25)">
                        @Lang.T("MyStore")
                    </MudButton>
                    <MudButton Href="/seller/mystore" Variant="Variant.Outlined" Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.AddBusiness" FullWidth="true"
                               Style="height:48px">
                        Đăng ký gian hàng mới
                    </MudButton>
                </MudStack>
            </MudPaper>

            <MudPaper Class="pa-6 glass-card animate-fade-in-up delay-4" Elevation="0">
                <MudText Typo="Typo.subtitle1" Style="font-weight:700" Class="mb-4">🏪 @Lang.T("MyStore")</MudText>
                <MudStack Spacing="3">
                    @foreach (var s in _myStores.Take(5))
                    {
                        <div class="d-flex align-center pa-2 rounded-lg hover-bg" style="transition:0.2s">
                            <MudAvatar Size="Size.Medium" Color="Color.Primary" Variant="Variant.Outlined">@s.Name[0]</MudAvatar>
                            <MudStack Spacing="0" Class="ml-3" Style="flex:1">
                                <MudText Typo="Typo.body2" Style="font-weight:700">@s.Name</MudText>
                                <MudText Typo="Typo.caption" Style="opacity:0.6">@s.Category</MudText>
                            </MudStack>
                            <MudChip T="string" Size="Size.Small" 
                                     Variant="Variant.Text"
                                     Color="@(s.Status=="Active"?Color.Success:s.Status=="Pending"?Color.Warning:Color.Error)">
                                @s.Status.ToString()
                            </MudChip>
                        </div>
                    }
                    @if (!_myStores.Any())
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true" Class="text-center">
                            Chưa có gian hàng nào
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>
        </MudStack>
    </MudItem>
</MudGrid>

@code {
    private bool _loading = true;
    private List<StatModel> _stats = new();
    private List<StoreModel> _myStores = new();
    private int _totalListens, _totalViews, _totalReviews, _activeCount;

    // Không dùng const nữa, đổi thành biến chứa ID thật
    private int _currentSellerId = 0; 

    protected override async Task OnInitializedAsync()
    {
        Lang.OnLanguageChanged += HandleLanguageChanged;
        await LoadData();
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(async () => {
            await LoadData();
            StateHasChanged();
        });
    }

    private async Task LoadData()
    {
        _loading = true;
        // 1. Lấy thông tin người dùng đang đăng nhập
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;

        // 2. Tìm ID thật sự của họ
        if (user.Identity is not null && user.Identity.IsAuthenticated)
        {
            var idClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (idClaim != null && int.TryParse(idClaim.Value, out int parsedId))
            {
                _currentSellerId = parsedId;
            }
        }

        // 3. Gọi API với ID thật
        _myStores = await StoreSvc.GetStoresAsync(_currentSellerId);
        _stats = await StoreSvc.GetSellerStatsAsync(_currentSellerId);

        _totalListens = _myStores.Sum(s => s.TotalListens);
        _totalViews   = _myStores.Sum(s => s.TotalViews);
        _totalReviews = _stats.Sum(s => s.TotalReviews);
        _activeCount  = _myStores.Count(s => s.Status == "Active");
        _loading = false;
    }
    public void Dispose()
    {
        Lang.OnLanguageChanged -= HandleLanguageChanged;
    }
}
