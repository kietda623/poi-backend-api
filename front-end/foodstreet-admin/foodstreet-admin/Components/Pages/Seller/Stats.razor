@attribute [Authorize(Roles = "OWNER")]
@page "/seller/stats"
@page "/seller/stats/{StoreId:int}"
@layout SellerLayout
@rendermode InteractiveServer
@using MudBlazor
@inject foodstreet_admin.Services.StoreService StoreSvc
@inject AuthenticationStateProvider AuthState

<PageTitle>Thống kê doanh thu</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6 animate-fade-in-up">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h4" Style="font-weight:800"><span class="gradient-text-safe">Thống kê doanh thu</span></MudText>
        <MudText Typo="Typo.body2" Style="opacity:0.6">Chỉ hiện doanh thu</MudText>
    </MudStack>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.PictureAsPdf"
               Color="Color.Error" Size="Size.Small" Class="mr-2"
               Style="border-radius:12px">Export PDF</MudButton>
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.TableChart"
               Color="Color.Success" Size="Size.Small"
               Style="border-radius:12px">Export Excel</MudButton>
</MudStack>

<MudPaper Class="pa-3 mb-4 glass-card animate-fade-in-up" Elevation="0">
    <MudGrid AlignItems="AlignItems.Center">
        <MudItem xs="12" md="4">
            <MudSelect @bind-Value="selectedPeriod" @bind-Value:after="LoadAllData" Label="Khoảng thời gian" Variant="Variant.Outlined" Dense="true">
                <MudSelectItem Value="@("week")">Tuần</MudSelectItem>
                <MudSelectItem Value="@("month")">Tháng</MudSelectItem>
                <MudSelectItem Value="@("quarter")">Quý</MudSelectItem>
                <MudSelectItem Value="@("year")">Năm</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="1">
                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Color="Color.Primary"
                               OnClick="PreviousPeriod" Title="Kỳ trước" />
                <MudText Typo="Typo.body2" Style="font-weight:600; white-space:nowrap">
                    @rangeStartDisplay - @rangeEndDisplay
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Primary"
                               OnClick="NextPeriod" Title="Kỳ sau" />
                <MudIconButton Icon="@Icons.Material.Filled.Today" Color="Color.Secondary"
                               OnClick="GoToCurrentPeriod" Title="Hiện tại" />
            </MudStack>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="LoadAllData" FullWidth="true" Style="border-radius:12px; box-shadow: 0 6px 20px rgba(99, 102, 241, 0.3)">Làm mới dữ liệu</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Class="pa-4 text-center glass-card animate-fade-in-up delay-1 mb-4" Elevation="0">
    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Warning" Size="Size.Large" />
    <MudText Typo="Typo.h4" Color="Color.Warning"><b>@FormatCurrency(totalRevenue)</b></MudText>
    <MudText Typo="Typo.body2">Doanh thu</MudText>
</MudPaper>

@if (isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4 glass-card animate-fade-in-up delay-2" Elevation="0">
            <MudText Typo="Typo.h6" Class="mb-3">Doanh thu theo kỳ</MudText>
            <MudTable Items="@revenueBreakdown" Hover="true" Dense="true" Striped="true">
                <HeaderContent>
                    <MudTh>Mốc thời gian</MudTh>
                    <MudTh>Đơn hàng</MudTh>
                    <MudTh>Doanh thu</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Label</MudTd>
                    <MudTd>@context.OrderCount</MudTd>
                    <MudTd>
                        <MudProgressLinear Value="@GetRevenueProgress(context.Revenue)" Color="Color.Warning" Rounded="true" Class="my-1" />
                        <MudText Typo="Typo.caption">@FormatCurrency(context.Revenue)</MudText>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText>Chưa có dữ liệu doanh thu.</MudText>
                </NoRecordsContent>
            </MudTable>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4 glass-card animate-fade-in-up delay-4" Elevation="0">
            <MudText Typo="Typo.h6" Class="mb-3">Đánh giá từ khách hàng</MudText>
            <MudTable Items="@recentReviews" Hover="true" Dense="true" Striped="true">
                <HeaderContent>
                    <MudTh>Khách hàng</MudTh>
                    <MudTh>Đánh giá</MudTh>
                    <MudTh>Sao</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Khách hàng">@context.CustomerName</MudTd>
                    <MudTd DataLabel="Đánh giá">
                        <MudTooltip Text="@context.Comment">
                            <MudText Typo="Typo.body2" Style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @context.Comment
                            </MudText>
                        </MudTooltip>
                    </MudTd>
                    <MudTd DataLabel="Sao">
                        <MudRating SelectedValue="@context.Rating" ReadOnly="true" Size="Size.Small" />
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText>Chưa có đánh giá nào từ khách hàng.</MudText>
                </NoRecordsContent>
            </MudTable>
        </MudPaper>
    </MudItem>
    <MudItem xs="12">
        <MudPaper Class="pa-4 glass-card animate-fade-in-up delay-5" Elevation="0">
            <MudText Typo="Typo.h6" Class="mb-3">Danh sách đăng ký gần đây</MudText>
            <MudTable Items="@recentTransactions" Hover="true" Dense="true" Striped="true" FixedHeader="true" Height="300px">
                <HeaderContent>
                    <MudTh>Khách hàng</MudTh>
                    <MudTh>Gói dịch vụ</MudTh>
                    <MudTh>Thời gian kích hoạt</MudTh>
                    <MudTh>Số tiền</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Khách hàng">
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudAvatar Color="Color.Primary" Size="Size.Small">@context.CustomerName[0]</MudAvatar>
                            <MudText>@context.CustomerName</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Gói dịch vụ">
                        <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Text">@context.PackageName</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Thời gian kích hoạt">@context.Date.ToString("dd/MM/yyyy HH:mm")</MudTd>
                    <MudTd DataLabel="Số tiền">
                        <MudText Style="font-weight:700; color: #059669">@FormatCurrency(context.Price)</MudText>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText>Chưa có giao dịch thanh toán nào được ghi nhận.</MudText>
                </NoRecordsContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    [Parameter] public int StoreId { get; set; }

    private int selectedStoreId;
    private string selectedPeriod = "week";
    private int currentSellerId;
    private bool isLoading;
    private DateTime currentAnchorDate = DateTime.UtcNow;
    private string rangeStartDisplay = "";
    private string rangeEndDisplay = "";
    private List<foodstreet_admin.Models.StoreModel> myStores = new();
    private decimal totalRevenue;
    private List<foodstreet_admin.Models.SellerRevenueBreakdownItem> revenueBreakdown = new();
    private List<foodstreet_admin.Models.ShopRevenueItem> revenueByShop = new();
    private List<foodstreet_admin.Models.SellerTransactionItem> recentTransactions = new();
    private List<foodstreet_admin.Models.ReviewModel> recentReviews = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is not null && user.Identity.IsAuthenticated)
        {
            var idClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (idClaim != null && int.TryParse(idClaim.Value, out var parsedId))
            {
                currentSellerId = parsedId;
            }
        }

        await LoadAllData();
    }

    private async Task LoadAllData()
    {
        myStores = await StoreSvc.GetStoresAsync(currentSellerId);
        await LoadOverviewData();
    }

    private async Task LoadOverviewData()
    {
        isLoading = true;
        StateHasChanged();

        var overview = await StoreSvc.GetSellerOverviewAsync(currentSellerId, selectedPeriod, currentAnchorDate.ToString("yyyy-MM-dd"), selectedStoreId);

        if (overview != null)
        {
            totalRevenue = overview.TotalRevenue;
            revenueBreakdown = overview.RevenueBreakdown;
            revenueByShop = overview.RevenueByShop;
            recentTransactions = overview.RecentTransactions;
            recentReviews = await StoreSvc.GetStoreReviewsAsync(0, currentSellerId);
            rangeStartDisplay = overview.StartDate;
            rangeEndDisplay = overview.EndDate;
        }
        else
        {
            totalRevenue = 0;
            revenueBreakdown = new();
            revenueByShop = new();
            recentTransactions = new();
            recentReviews = new();
            rangeStartDisplay = currentAnchorDate.ToString("yyyy-MM-dd");
            rangeEndDisplay = currentAnchorDate.ToString("yyyy-MM-dd");
        }

        isLoading = false;
        StateHasChanged();
    }

    private decimal GetRevenueMax()
    {
        var maxPeriod = revenueBreakdown.Any() ? revenueBreakdown.Max(x => x.Revenue) : 0;
        var maxShop = revenueByShop.Any() ? revenueByShop.Max(x => x.Revenue) : 0;
        return new[] { totalRevenue, maxPeriod, maxShop }.Max();
    }

    private double GetRevenueProgress(decimal revenue)
    {
        var maxRevenue = GetRevenueMax();
        if (maxRevenue <= 0)
        {
            return 0;
        }
        return (double)(revenue / maxRevenue) * 100d;
    }

    private static string FormatCurrency(decimal value) => $"{value:N0} đ";

    private async Task PreviousPeriod()
    {
        currentAnchorDate = selectedPeriod switch
        {
            "month" => currentAnchorDate.AddMonths(-1),
            "quarter" => currentAnchorDate.AddMonths(-3),
            "year" => currentAnchorDate.AddYears(-1),
            _ => currentAnchorDate.AddDays(-7)
        };

        await LoadOverviewData();
    }

    private async Task NextPeriod()
    {
        currentAnchorDate = selectedPeriod switch
        {
            "month" => currentAnchorDate.AddMonths(1),
            "quarter" => currentAnchorDate.AddMonths(3),
            "year" => currentAnchorDate.AddYears(1),
            _ => currentAnchorDate.AddDays(7)
        };

        await LoadOverviewData();
    }

    private async Task GoToCurrentPeriod()
    {
        currentAnchorDate = DateTime.UtcNow;
        await LoadOverviewData();
    }

    protected override void OnParametersSet()
    {
        if (StoreId > 0)
        {
            selectedStoreId = StoreId;
        }
    }
}
