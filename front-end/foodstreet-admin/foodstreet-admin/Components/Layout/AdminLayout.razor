@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject AuthService AuthSvc
@inject StoreService StoreSvc

<MudLayout>
    <MudAppBar Elevation="0" Dense="false" Class="glass-effect sticky-top">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="ml-1">
            <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary" Style="font-size: 1.5rem;" />
            <MudText Typo="Typo.h6" Class="gradient-text-safe" Style="font-weight:800; letter-spacing: -0.5px; margin-left: 4px;">
                FoodStreet <span style="font-weight:400; color: #64748b">Admin</span>
            </MudText>
        </MudStack>
        <MudSpacer />
        <MudBadge Content="@_pendingCount" Color="Color.Warning"
                  Overlap="true" Visible="@(_pendingCount > 0)">
            <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" />
        </MudBadge>
        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
            <ActivatorContent>
                <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" />
            </ActivatorContent>
            <ChildContent>
                <MudText Class="px-4 py-2" Typo="Typo.body2" Color="Color.Secondary">
                    admin@foodstreet.vn
                </MudText>
                <MudDivider />
                <MudMenuItem Href="/auth/logout" Target="_top" Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error">
                    Đăng xuất
                </MudMenuItem>
            </ChildContent>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_open" ClipMode="DrawerClipMode.Always"
               Elevation="0" Variant="DrawerVariant.Responsive" Class="glass-effect">
        
        <div class="d-flex flex-column" style="height: 100%;">
            
            <div>
                <MudDrawerHeader Style="padding:12px 16px">
                    <MudStack Spacing="1" AlignItems="AlignItems.Center" Row="true" Class="w-100">
                        <MudAvatar Color="Color.Warning" Size="Size.Medium" Class="mud-elevation-2" 
                                   Style="background: var(--primary-gradient); color: white; font-weight: 700">
                            AD
                        </MudAvatar>
                        <MudStack Spacing="0" Class="ml-2">
                            <MudText Typo="Typo.body2" Style="font-weight:700; color: #1e293b">
                                Quản trị viên
                            </MudText>
                            <MudText Typo="Typo.caption" Style="color: #64748b; font-weight: 500; line-height: 1">
                                Super Administrator
                            </MudText>
                        </MudStack>
                    </MudStack>
                </MudDrawerHeader>
                <MudDivider />
            </div>

            <div class="flex-grow-1" style="overflow-y: auto; overflow-x: hidden;">
                <MudNavMenu Class="pa-1">
    <MudNavLink Href="/admin/dashboard" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>

    <MudNavGroup Title="Quản lý Người dùng" Icon="@Icons.Material.Filled.People" Expanded="true">
        <MudNavLink Href="/admin/manage-user" Icon="@Icons.Material.Filled.Group" Class="pl-6">Tất cả Người dùng</MudNavLink>
        <MudNavLink Href="/admin/manage-seller" Icon="@Icons.Material.Filled.SupervisorAccount" Class="pl-6">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudText>Người bán (Seller)</MudText>
                @if (_pendingCount > 0)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                             Style="height:16px;font-size:10px;min-width:0;padding:0 6px">
                        @_pendingCount
                    </MudChip>
                }
            </MudStack>
        </MudNavLink>
        <MudNavLink Href="/admin/manage-customer" Icon="@Icons.Material.Filled.PersonOutline" Class="pl-6">Khách tham quan</MudNavLink>
    </MudNavGroup>

    <MudNavGroup Title="Quản lý Dịch vụ" Icon="@Icons.Material.Filled.Storefront" Expanded="true">
        <MudNavLink Href="/admin/manage-store" Icon="@Icons.Material.Filled.Store" Class="pl-6">Gian hàng (Store)</MudNavLink>
        <MudNavLink Href="/admin/manage-poi" Icon="@Icons.Material.Filled.Place" Class="pl-6">Điểm tham quan (POI)</MudNavLink>
        <MudNavLink Href="/admin/manage-category" Icon="@Icons.Material.Filled.Category" Class="pl-6">Danh mục quán</MudNavLink>
        <MudNavLink Href="/admin/manage-service-package" Icon="@Icons.Material.Filled.Inventory2" Class="pl-6">Gói dịch vụ & đăng ký</MudNavLink>
        <MudNavLink Href="/admin/manage-language" Icon="@Icons.Material.Filled.LibraryMusic" Class="pl-6">File Audio Gian Hàng</MudNavLink>
        <MudNavLink Href="/admin/usage-history" Icon="@Icons.Material.Filled.History" Class="pl-6">Lịch sử nghe</MudNavLink>
    </MudNavGroup>

    <MudDivider Class="my-2" />

    <MudNavLink Href="/admin/stats" Icon="@Icons.Material.Filled.BarChart">Thống kê doanh thu</MudNavLink>
    <MudNavLink Href="/admin/settings" Icon="@Icons.Material.Filled.Settings">Cài đặt hệ thống</MudNavLink>
</MudNavMenu>
            </div>

            <div class="pa-2">
                <MudDivider Class="my-2" />
                <MudNavMenu>
                    <MudNavLink Href="/auth/logout" Target="_top" Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error">
                        Đăng xuất
                    </MudNavLink>
                </MudNavMenu>
            </div>

        </div>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4 pa-md-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<AppProviders />

@code {
    private bool _open = true;
    private int _pendingCount = 0;
    
    // Ghi nhớ trạng thái đóng/mở của menu Quản lý (mặc định cho mở)
    private bool _manageExpanded = true; 

    private void ToggleDrawer() => _open = !_open;

    protected override async Task OnInitializedAsync()
    {
        var stores = await StoreSvc.GetStoresAsync();
        _pendingCount = stores.Count(s => s.Status == "Pending");
    }
}

