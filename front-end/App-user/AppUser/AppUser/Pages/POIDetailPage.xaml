<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppUser.Pages.POIDetailPage"
    x:Name="this"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AppUser.ViewModels"
    xmlns:models="clr-namespace:AppUser.Models"
    x:DataType="vm:POIDetailViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource Background}">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- ── HERO IMAGE ── -->
                <Grid HeightRequest="400">
                    <Image Source="{Binding POI.ImageUrl}"
                           Aspect="AspectFill"
                           HeightRequest="400"
                           HorizontalOptions="Fill"/>

                    <!-- Dark gradient overlay -->
                    <BoxView HorizontalOptions="Fill" VerticalOptions="Fill">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#200F172A" Offset="0" />
                                <GradientStop Color="#600F172A" Offset="0.6" />
                                <GradientStop Color="#D00F172A" Offset="1" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Back button (Glass) -->
                    <Border Style="{StaticResource GlassBorder}"
                            WidthRequest="48" HeightRequest="48"
                            HorizontalOptions="Start"
                            VerticalOptions="Start"
                            Margin="16,48,0,0"
                            Padding="0">
                        <Button Text="←"
                                Command="{Binding GoBackCommand}"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                FontSize="22"
                                Padding="0"/>
                    </Border>

                    <!-- Language toggle (Glass) -->
                    <Border Style="{StaticResource GlassBorder}"
                            Padding="12,4"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            Margin="0,52,16,0"
                            HeightRequest="40"
                            IsVisible="False">
                        <Button Text="{Binding CurrentLanguage, StringFormat='🌐 {0}'}"
                                Command="{Binding ToggleLanguageCommand}"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                FontFamily="BeVietnamProBold"
                                FontSize="13"
                                Padding="0"/>
                    </Border>

                    <!-- POI Name on image -->
                    <VerticalStackLayout VerticalOptions="End"
                                         HorizontalOptions="Start"
                                         Padding="20,24">
                        <Label Text="{Binding DisplayName}"
                               Style="{StaticResource HeadlineLarge}"
                               TextColor="White"
                               FontSize="28"
                               LineBreakMode="WordWrap"
                               FontFamily="BeVietnamProBold"/>
                        <HorizontalStackLayout Spacing="8" Margin="0,6,0,0">
                            <Label Text="📍" FontSize="14" TextColor="White" Opacity="0.9"/>
                            <Label Text="{Binding POI.Location}"
                                   Style="{StaticResource BodyMedium}"
                                   TextColor="#E2E8F0"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"
                                   FontFamily="BeVietnamPro"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>

                <!-- ── MAIN CONTENT CARD ── -->
                <Border BackgroundColor="{StaticResource Background}"
                        StrokeShape="RoundRectangle 30,30,0,0"
                        StrokeThickness="0"
                        Margin="0,-30,0,0"
                        Padding="20,32,20,20">

                    <VerticalStackLayout Spacing="24">

                        <!-- ── AUDIO PLAYER PREVIEW ── -->
                        <Border BackgroundColor="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 20"
                                StrokeThickness="0"
                                Padding="20,16"
                                IsVisible="True">
                            <Border.Shadow>
                                <Shadow Brush="{StaticResource Primary}" Offset="0,10" Radius="20" Opacity="0.3"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label Text="{Binding AudioGuideLabel, StringFormat='🎧 {0}'}"
                                           Style="{StaticResource TitleMedium}"
                                           TextColor="White"
                                           Opacity="0.8"
                                           FontFamily="BeVietnamProMedium"/>
                                    <Label Text="{Binding CurrentAudioGuide.Title}"
                                           Style="{StaticResource TitleLarge}"
                                           TextColor="White"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1"
                                           FontFamily="BeVietnamProBold"/>
                                    <Label Text="{Binding CurrentAudioGuide.DurationDisplay, StringFormat='⏱️ {0}'}"
                                           Style="{StaticResource LabelCaption}"
                                           TextColor="#B2FFFFFF"
                                           FontFamily="BeVietnamPro"/>
                                </VerticalStackLayout>

                                <Button Grid.Column="1"
                                        Text="{Binding PlayButtonLabel, StringFormat='▶ {0}'}"
                                        Command="{Binding PlayAudioCommand}"
                                        BackgroundColor="White"
                                        TextColor="{StaticResource Primary}"
                                        FontFamily="BeVietnamProBold"
                                        FontSize="14"
                                        CornerRadius="12"
                                        HeightRequest="44"
                                        Padding="16,0"
                                        VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- No audio state -->
                        <Border BackgroundColor="{StaticResource SurfaceVariant}"
                                StrokeShape="RoundRectangle 16"
                                StrokeThickness="0"
                                Padding="16,14"
                                IsVisible="{Binding HasAudio, Converter={StaticResource BoolInverterConverter}}">
                            <Label Text="{Binding NoAudioLabel, StringFormat='🔇 {0}'}"
                                   Style="{StaticResource BodyMedium}"
                                   TextColor="{StaticResource TextHint}"
                                   HorizontalOptions="Center"
                                   FontFamily="BeVietnamPro"/>
                        </Border>

                        <!-- ── DESCRIPTION ── -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding IntroLabel}"
                                   Style="{StaticResource HeadlineSmall}"
                                   TextColor="{StaticResource Primary}"
                                   FontFamily="BeVietnamProBold"/>
                            <Label Text="{Binding DisplayDescription}"
                                   Style="{StaticResource BodyLarge}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontFamily="BeVietnamPro"/>
                        </VerticalStackLayout>

                        <!-- ── DIVIDER ── -->
                        <BoxView Style="{StaticResource Divider}" Margin="0,4"/>

                        <!-- ── MENU SECTION ── -->
                        <VerticalStackLayout Spacing="16">
                            <Label Text="{Binding MenuLabel, StringFormat='🍽️ {0}'}"
                                   Style="{StaticResource HeadlineSmall}"
                                   TextColor="{StaticResource Primary}"
                                   FontFamily="BeVietnamProBold"/>

                            <!-- Menu Gallery (Fallback if structured menus not used or as additional images) -->
                            <CollectionView ItemsSource="{Binding MenuGalleryImages}"
                                            HeightRequest="200"
                                            Margin="0,0,0,16"
                                            IsVisible="{Binding MenuGalleryImages.Count, Converter={StaticResource IntToBoolConverter}}">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border StrokeShape="RoundRectangle 16"
                                                StrokeThickness="0"
                                                WidthRequest="280">
                                            <Image Source="{Binding .}"
                                                   Aspect="AspectFill"
                                                   HorizontalOptions="Fill"
                                                   VerticalOptions="Fill"/>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <!-- Menu Groups -->
                            <VerticalStackLayout
                                BindableLayout.ItemsSource="{Binding POI.Shop.Menus}"
                                Spacing="20">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:MenuDto">
                                        <VerticalStackLayout Spacing="12" Margin="0,0,0,4">
                                            <Label Text="{Binding Name}"
                                                   Style="{StaticResource TitleLarge}"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   FontSize="18"
                                                   FontFamily="BeVietnamProBold"/>

                                            <VerticalStackLayout
                                                BindableLayout.ItemsSource="{Binding Items}"
                                                Spacing="16">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="models:MenuItemDto">
                                                        <Border Style="{StaticResource PremiumBorder}"
                                                                Padding="12">
                                                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="16">
                                                                <Border Grid.Column="0"
                                                                        WidthRequest="84" HeightRequest="84"
                                                                        StrokeShape="RoundRectangle 16"
                                                                        StrokeThickness="0"
                                                                        BackgroundColor="#F1F5F9"
                                                                        IsVisible="{Binding ImageUrl, Converter={StaticResource StringNotEmptyConverter}}">
                                                                    <Image Source="{Binding ImageUrl}"
                                                                           Aspect="AspectFill"
                                                                           WidthRequest="84" HeightRequest="84"/>
                                                                </Border>

                                                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                                                    <Label Text="{Binding Name}"
                                                                           Style="{StaticResource TitleMedium}"
                                                                           TextColor="{StaticResource TextPrimary}"
                                                                           FontSize="16"
                                                                           FontFamily="BeVietnamProBold"/>
                                                                    <Label Text="{Binding Description}"
                                                                           Style="{StaticResource BodySmall}"
                                                                           TextColor="{StaticResource TextSecondary}"
                                                                           LineBreakMode="TailTruncation"
                                                                           MaxLines="2"
                                                                           IsVisible="{Binding Description, Converter={StaticResource StringNotEmptyConverter}}"
                                                                           FontFamily="BeVietnamPro"/>
                                                                    <Label Text="{Binding PriceDisplay}"
                                                                           Style="{StaticResource TitleLarge}"
                                                                           TextColor="{StaticResource Primary}"
                                                                           FontSize="17"
                                                                           Margin="0,4,0,0"
                                                                           FontFamily="BeVietnamProBold"/>
                                                                </VerticalStackLayout>

                                                                <VerticalStackLayout Grid.Column="2"
                                                                                     HorizontalOptions="End"
                                                                                     VerticalOptions="Start">
                                                                    <Border BackgroundColor="#DCFCE7"
                                                                            StrokeShape="RoundRectangle 8"
                                                                            StrokeThickness="0"
                                                                            Padding="8,4"
                                                                            IsVisible="{Binding IsAvailable}">
                                                                        <Label Text="{Binding BindingContext.InStockLabel, Source={x:Reference Name=this}}"
                                                                               Style="{StaticResource LabelCaption}"
                                                                               TextColor="{StaticResource Success}"
                                                                               FontSize="11"
                                                                               FontFamily="BeVietnamProBold"/>
                                                                    </Border>
                                                                </VerticalStackLayout>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- Bottom padding -->
                <BoxView HeightRequest="80" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ── FLOATING PLAY BUTTON ── -->
        <Border StrokeShape="RoundRectangle 28"
                StrokeThickness="0"
                IsVisible="True"
                HorizontalOptions="Fill"
                VerticalOptions="End"
                Margin="24,0,24,32"
                HeightRequest="60">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                    <GradientStop Color="{StaticResource PrimaryLight}" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="{StaticResource Primary}" Offset="0,10" Radius="20" Opacity="0.4"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding PlayAudioCommand}" />
            </Border.GestureRecognizers>
            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                <Label Text="🎧" FontSize="26" TextColor="White" VerticalOptions="Center"/>
                <Label Text="{Binding ListenNowLabel}" FontFamily="BeVietnamProBold" FontSize="17" TextColor="White" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Border>
    </Grid>
</ContentPage>
