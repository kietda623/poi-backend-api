<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppUser.Pages.AudioPlayerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AppUser.ViewModels"
    xmlns:models="clr-namespace:AppUser.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:DataType="vm:AudioPlayerViewModel"
    Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <!-- Animations for button feedback -->
        <Style x:Key="MediaControlButtonStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="White" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="Scale" Value="1" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Scale" Value="0.85" />
                                <Setter Property="Opacity" Value="0.7" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
        <Style x:Key="GlassBorder" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#15FFFFFF" />
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        </Style>
    </ContentPage.Resources>

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F172A" Offset="0.0" />
            <GradientStop Color="#1E1E3F" Offset="0.5" />
            <GradientStop Color="#020617" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*">
        
        <!-- MediaElement for playback (hidden) -->
        <toolkit:MediaElement x:Name="MediaElement"
                               Source="{Binding AudioUrl}"
                               ShouldAutoPlay="True"
                               ShouldShowPlaybackControls="False"
                               PositionChanged="OnMediaElementPositionChanged"
                               StateChanged="OnMediaElementStateChanged"
                               IsVisible="False" />

        <!-- ── TOP BAR (Glassmorphism) ── -->
        <Grid Grid.Row="0" RowDefinitions="Auto,Auto" Padding="16,52,16,16">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                <Border Grid.Column="0"
                        Style="{StaticResource GlassBorder}"
                        WidthRequest="48" HeightRequest="48"
                        Padding="0">
                    <Button Text="←"
                            Style="{StaticResource MediaControlButtonStyle}"
                            Command="{Binding GoBackCommand}"
                            FontSize="22"
                            Padding="0"/>
                </Border>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <Label Text="{Binding NowPlayingLabel}"
                           FontFamily="PoppinsBold"
                           FontSize="10"
                           TextColor="#99FFFFFF"
                           HorizontalOptions="Center"
                           CharacterSpacing="2"/>
                    <Label Text="{Binding POIName}"
                           FontSize="14"
                           FontFamily="PoppinsSemiBold"
                           TextColor="White"
                           HorizontalOptions="Center"
                           Opacity="0.9"/>
                </VerticalStackLayout>

                <Border Grid.Column="2"
                        Style="{StaticResource GlassBorder}"
                        Padding="12,0"
                        HeightRequest="36">
                    <Button Text="{Binding PlaybackSpeed, StringFormat='{0}x'}"
                            Style="{StaticResource MediaControlButtonStyle}"
                            Command="{Binding CycleSpeedCommand}"
                            FontFamily="PoppinsBold"
                            FontSize="12"
                            Padding="0"/>
                </Border>
            </Grid>

            <!-- Language Selector -->
            <ScrollView Grid.Row="1" 
                        Orientation="Horizontal" 
                        HorizontalScrollBarVisibility="Never"
                        IsVisible="{Binding HasMultipleLanguages}"
                        Margin="0,24,0,0">
                <HorizontalStackLayout BindableLayout.ItemsSource="{Binding AvailableLanguages}" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:AppLanguageDto">
                            <Border StrokeShape="RoundRectangle 14"
                                    StrokeThickness="0"
                                    BackgroundColor="#15FFFFFF"
                                    Padding="14,6">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AudioPlayerViewModel}}, Path=SwitchLanguageCommand}"
                                                          CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Label Text="{Binding Name}" 
                                       TextColor="White" 
                                       FontSize="12"
                                       FontFamily="PoppinsMedium"
                                       Opacity="0.7">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding Code}" Value="{Binding Source={RelativeSource AncestorType={x:Type vm:AudioPlayerViewModel}}, Path=CurrentLangCode}">
                                            <Setter Property="TextColor" Value="{StaticResource Primary}" />
                                            <Setter Property="FontAttributes" Value="Bold" />
                                            <Setter Property="Opacity" Value="1" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>
        </Grid>

        <!-- ── PLAYER CENTER CONTENT ── -->
        <VerticalStackLayout Grid.Row="1"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Padding="32,0">

            <!-- Immersive Album Art -->
            <Border x:Name="AlbumArtBorder"
                    StrokeShape="RoundRectangle 140"
                    StrokeThickness="8"
                    Stroke="#15FFFFFF"
                    WidthRequest="280" HeightRequest="280"
                    HorizontalOptions="Center"
                    Margin="0,0,0,48">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Primary}" Offset="0,15" Radius="40" Opacity="0.3"/>
                </Border.Shadow>
                <Image Source="{Binding ImageUrl}"
                       Aspect="AspectFill"
                       WidthRequest="280"
                       HeightRequest="280"/>
            </Border>

            <!-- Guide Details -->
            <Label Text="{Binding GuideTitle}"
                   FontSize="26"
                   FontFamily="PoppinsBold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,10"/>
            <Label Text="{Binding SubTitleLabel}"
                   FontSize="15"
                   FontFamily="PoppinsMedium"
                   TextColor="{StaticResource Primary}"
                   HorizontalOptions="Center"
                   Opacity="0.9"
                   Margin="0,0,0,48"/>

            <!-- ── PROGRESS BAR ── -->
            <VerticalStackLayout Spacing="12" HorizontalOptions="Fill" Margin="0,0,0,48">
                <Slider Value="{Binding Progress}"
                        Minimum="0" Maximum="1"
                        MinimumTrackColor="{StaticResource Primary}"
                        MaximumTrackColor="#15FFFFFF"
                        ThumbColor="White"/>

                <Grid ColumnDefinitions="*,*">
                    <Label Grid.Column="0"
                           Text="{Binding PositionText}"
                           FontSize="13"
                           TextColor="#99FFFFFF"
                           FontFamily="PoppinsMedium"/>
                    <Label Grid.Column="1"
                           Text="{Binding DurationText}"
                           FontSize="13"
                           TextColor="#99FFFFFF"
                           FontFamily="PoppinsMedium"
                           HorizontalOptions="End"/>
                </Grid>
            </VerticalStackLayout>

            <!-- ── CONTROLS ── -->
            <Grid ColumnDefinitions="*,Auto,*"
                  HorizontalOptions="Fill"
                  VerticalOptions="Center">

                <Button Grid.Column="0"
                        Text="⏪"
                        Style="{StaticResource MediaControlButtonStyle}"
                        Command="{Binding SeekBackwardCommand}"
                        FontSize="40"
                        HorizontalOptions="Center"/>

                <Border Grid.Column="1"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 45"
                        StrokeThickness="0"
                        WidthRequest="90" HeightRequest="90">
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource Primary}" Offset="0,15" Radius="30" Opacity="0.4"/>
                    </Border.Shadow>
                    <Button x:Name="PlayPauseBtn"
                            Style="{StaticResource MediaControlButtonStyle}"
                            Command="{Binding TogglePlayPauseCommand}"
                            TextColor="#0F172A"
                            FontSize="44"
                            WidthRequest="90" HeightRequest="90">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsPlaying}" Value="True">
                                <Setter Property="Text" Value="⏸" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button" Binding="{Binding IsPlaying}" Value="False">
                                <Setter Property="Text" Value="▶" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Border>

                <Button Grid.Column="2"
                        Text="⏩"
                        Style="{StaticResource MediaControlButtonStyle}"
                        Command="{Binding SeekForwardCommand}"
                        FontSize="40"
                        HorizontalOptions="Center"/>
            </Grid>

        </VerticalStackLayout>
    </Grid>
</ContentPage>
