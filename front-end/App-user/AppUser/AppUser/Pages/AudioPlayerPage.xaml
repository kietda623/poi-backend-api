<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppUser.Pages.AudioPlayerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AppUser.ViewModels"
    xmlns:models="clr-namespace:AppUser.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:DataType="vm:AudioPlayerViewModel"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <ContentPage.Resources>
        <!-- Animations for button feedback -->
        <Style x:Key="MediaControlButtonStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="White" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="Scale" Value="1" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Scale" Value="0.85" />
                                <Setter Property="Opacity" Value="0.7" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
        <Style x:Key="GlassBorder" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#15FFFFFF" />
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        </Style>
    </ContentPage.Resources>

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F172A" Offset="0.0" />
            <GradientStop Color="#1E1E3F" Offset="0.5" />
            <GradientStop Color="#020617" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid>
        <Grid RowDefinitions="Auto,*">
        
        <!-- MediaElement for playback (hidden but must be in visual tree) -->
        <toolkit:MediaElement x:Name="MediaElement"
                               ShouldAutoPlay="False"
                               ShouldShowPlaybackControls="False"
                               PositionChanged="OnMediaElementPositionChanged"
                               StateChanged="OnMediaElementStateChanged"
                               MediaFailed="OnMediaElementMediaFailed"
                               IsVisible="True"
                               WidthRequest="0"
                               HeightRequest="0"
                               Opacity="0" />

        <!-- ── TOP BAR (Glassmorphism) ── -->
        <Grid Grid.Row="0" RowDefinitions="Auto,Auto" Padding="16,52,16,16">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                <Border Grid.Column="0"
                        Style="{StaticResource GlassBorder}"
                        WidthRequest="48" HeightRequest="48"
                        Padding="0">
                    <Button Text="←"
                            Style="{StaticResource MediaControlButtonStyle}"
                            Command="{Binding GoBackCommand}"
                            FontSize="22"
                            Padding="0"/>
                </Border>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <Label Text="{Binding NowPlayingLabel}"
                           FontFamily="{x:Null}"
                           FontSize="10"
                           TextColor="#99FFFFFF"
                           HorizontalOptions="Center"
                           CharacterSpacing="2"/>
                    <Label Text="{Binding POIName}"
                           FontSize="14"
                           FontFamily="{x:Null}"
                           TextColor="White"
                           HorizontalOptions="Center"
                           Opacity="0.9"/>
                </VerticalStackLayout>

                <Border Grid.Column="2"
                        Style="{StaticResource GlassBorder}"
                        Padding="12,0"
                        HeightRequest="36">
                    <Button Text="{Binding PlaybackSpeed, StringFormat='{0}x'}"
                            Style="{StaticResource MediaControlButtonStyle}"
                            Command="{Binding CycleSpeedCommand}"
                            FontFamily="{x:Null}"
                            FontSize="12"
                            Padding="0"/>
                </Border>
            </Grid>

            <!-- Language Selector -->
            <HorizontalStackLayout Grid.Row="1"
                                   HorizontalOptions="Center"
                                   Spacing="10"
                                   IsVisible="{Binding HasMultipleLanguages}"
                                   Margin="0,24,0,0">
                <Button Text="Vietnamese"
                        Command="{Binding SwitchLanguageByCodeCommand}"
                        CommandParameter="vi"
                        FontFamily="{x:Null}"
                        FontSize="12"
                        Padding="16,8"
                        CornerRadius="14"
                        BackgroundColor="#15FFFFFF"
                        TextColor="White"
                        Opacity="1"
                        IsEnabled="{Binding CanPlayVietnamese}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsVietnameseSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="#2E6BFF" />
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button" Binding="{Binding CanPlayVietnamese}" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button Text="English"
                        Command="{Binding SwitchLanguageByCodeCommand}"
                        CommandParameter="en"
                        FontFamily="{x:Null}"
                        FontSize="12"
                        Padding="16,8"
                        CornerRadius="14"
                        BackgroundColor="#15FFFFFF"
                        TextColor="White"
                        Opacity="1"
                        IsEnabled="{Binding CanPlayEnglish}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsEnglishSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="#2E6BFF" />
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button" Binding="{Binding CanPlayEnglish}" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button Text="中文"
                        Command="{Binding SwitchLanguageByCodeCommand}"
                        CommandParameter="zh"
                        FontFamily="{x:Null}"
                        FontSize="12"
                        Padding="16,8"
                        CornerRadius="14"
                        BackgroundColor="#15FFFFFF"
                        TextColor="White"
                        Opacity="1"
                        IsEnabled="{Binding CanPlayChinese}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsChineseSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="#2E6BFF" />
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button" Binding="{Binding CanPlayChinese}" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </HorizontalStackLayout>
        </Grid>

        <!-- ── PLAYER CENTER CONTENT ── -->
        <VerticalStackLayout Grid.Row="1"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Padding="32,0">

            <!-- Immersive Album Art -->
            <Border x:Name="AlbumArtBorder"
                    StrokeShape="RoundRectangle 140"
                    StrokeThickness="8"
                    Stroke="#15FFFFFF"
                    WidthRequest="280" HeightRequest="280"
                    HorizontalOptions="Center"
                    Margin="0,0,0,48">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Primary}" Offset="0,15" Radius="40" Opacity="0.3"/>
                </Border.Shadow>
                <Image Source="{Binding ImageUrl}"
                       Aspect="AspectFill"
                       WidthRequest="280"
                       HeightRequest="280"/>
            </Border>

            <!-- Guide Details -->
            <Label Text="{Binding GuideTitle}"
                   FontSize="26"
                   FontFamily="{x:Null}"
                   TextColor="White"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,10"/>
            <Label Text="{Binding SubTitleLabel}"
                   FontSize="15"
                   FontFamily="{x:Null}"
                   TextColor="{StaticResource Primary}"
                   HorizontalOptions="Center"
                   Opacity="0.9"
                   Margin="0,0,0,48"/>

            <!-- ── PROGRESS BAR ── -->
            <VerticalStackLayout Spacing="12" HorizontalOptions="Fill" Margin="0,0,0,48">
                <Slider x:Name="ProgressSlider"
                        Value="{Binding Progress}"
                        Minimum="0" Maximum="1"
                        MinimumTrackColor="{StaticResource Primary}"
                        MaximumTrackColor="#15FFFFFF"
                        ThumbColor="White"
                        DragStarted="OnSliderDragStarted"
                        DragCompleted="OnSliderDragCompleted"/>

                <Grid ColumnDefinitions="*,*">
                    <Label Grid.Column="0"
                           Text="{Binding PositionText}"
                           FontSize="13"
                           TextColor="#99FFFFFF"
                           FontFamily="{x:Null}"/>
                    <Label Grid.Column="1"
                           Text="{Binding DurationText}"
                           FontSize="13"
                           TextColor="#99FFFFFF"
                           FontFamily="{x:Null}"
                           HorizontalOptions="End"/>
                </Grid>
            </VerticalStackLayout>

            <!-- ── CONTROLS ── -->
            <Grid ColumnDefinitions="*,Auto,*"
                  HorizontalOptions="Fill"
                  VerticalOptions="Center">

                <Button Grid.Column="0"
                        Text="⏮"
                        Style="{StaticResource MediaControlButtonStyle}"
                        Command="{Binding SeekBackwardCommand}"
                        FontSize="36"
                        HorizontalOptions="Center"/>

                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 45"
                        StrokeThickness="0"
                        WidthRequest="90" HeightRequest="90">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                            <GradientStop Color="{StaticResource PrimaryDark}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource Primary}" Offset="0,10" Radius="24" Opacity="0.5"/>
                    </Border.Shadow>
                    <Button x:Name="PlayPauseBtn"
                            Style="{StaticResource MediaControlButtonStyle}"
                            Command="{Binding TogglePlayPauseCommand}"
                            Text="▶"
                            TextColor="White"
                            FontSize="36"
                            WidthRequest="90" HeightRequest="90">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsPlaying}" Value="True">
                                <Setter Property="Text" Value="⏸" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button" Binding="{Binding IsPlaying}" Value="False">
                                <Setter Property="Text" Value="▶" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Border>

                <Button Grid.Column="2"
                        Text="⏭"
                        Style="{StaticResource MediaControlButtonStyle}"
                        Command="{Binding SeekForwardCommand}"
                        FontSize="36"
                        HorizontalOptions="Center"/>
            </Grid>

            <!-- Show Review Button -->
            <Button Text="Rate this audio guide"
                    Command="{Binding ShowReviewCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#99FFFFFF"
                    FontFamily="{x:Null}"
                    FontSize="12"
                    Margin="0,32,0,0"
                    HorizontalOptions="Center" />

        </VerticalStackLayout>

        <!-- In-app fallback player when MediaElement fails -->
        <Border Grid.Row="1"
                x:Name="FallbackAudioContainer"
                IsVisible="False"
                Margin="16"
                Padding="12"
                BackgroundColor="#1AFFFFFF"
                StrokeShape="RoundRectangle 12"
                StrokeThickness="0"
                VerticalOptions="End">
            <VerticalStackLayout Spacing="8">
                <Label Text="Fallback player"
                       FontSize="12"
                       TextColor="#CCFFFFFF"
                       HorizontalOptions="Center"
                       FontFamily="{x:Null}"/>
                <WebView x:Name="FallbackAudioWebView"
                         HeightRequest="96"/>
            </VerticalStackLayout>
        </Border>
    </Grid>

    <!-- ── REVIEW DIALOG OVERLAY ── -->
    <Grid IsVisible="{Binding IsReviewDialogVisible}" BackgroundColor="#D9000000">
        <!-- Review Card -->
        <Border BackgroundColor="#1E1E3F"
                StrokeShape="RoundRectangle 24"
                StrokeThickness="1"
                Stroke="#33FFFFFF"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="320"
                Padding="24">
            <VerticalStackLayout Spacing="16">
                
                <Label Text="Rate your experience"
                       FontSize="18"
                       FontFamily="{x:Null}"
                       TextColor="White"
                       HorizontalOptions="Center" />

                <!-- Simple Rating Label (Alternatively a Slider for rating) -->
                <Label Text="Rating (1-5)"
                       FontSize="12"
                       FontFamily="{x:Null}"
                       TextColor="#99FFFFFF"/>
                <Slider Minimum="1" Maximum="5" Value="{Binding ReviewRating}" 
                        MinimumTrackColor="{StaticResource Primary}" 
                        MaximumTrackColor="#33FFFFFF"
                        ThumbColor="White"/>
                <Label Text="{Binding ReviewRating, StringFormat='{0:F0} Stars'}"
                       TextColor="{StaticResource Primary}"
                       FontFamily="{x:Null}"
                       HorizontalOptions="Center"/>

                <Editor Placeholder="Share your feedback..."
                        Text="{Binding ReviewComment}"
                        PlaceholderColor="#66FFFFFF"
                        TextColor="White"
                        BackgroundColor="#2A2A5A"
                        HeightRequest="80"
                        Margin="0,0,0,16"
                        FontFamily="{x:Null}"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                    <Button Grid.Column="0"
                            Text="Cancel"
                            BackgroundColor="Transparent"
                            TextColor="#99FFFFFF"
                            BorderColor="#66FFFFFF"
                            BorderWidth="1"
                            CornerRadius="12"
                            Command="{Binding CancelReviewCommand}"
                            FontFamily="{x:Null}" />
                            
                    <Button Grid.Column="1"
                            Text="Submit"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="12"
                            Command="{Binding SubmitReviewCommand}"
                            FontFamily="{x:Null}" />
                </Grid>
                
            </VerticalStackLayout>
        </Border>
    </Grid>
    </Grid>

</ContentPage>
