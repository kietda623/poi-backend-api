<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppUser.Pages.POIListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AppUser.ViewModels"
    xmlns:models="clr-namespace:AppUser.Models"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── HEADER & SEARCH BAR ── -->
        <Border Grid.Row="0" Margin="0,-10,0,0" StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,32,32" />
            </Border.StrokeShape>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                    <GradientStop Color="{StaticResource PrimaryDark}" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <VerticalStackLayout Padding="20,24,20,32" Spacing="16">
                <!-- Title Header -->
                <HorizontalStackLayout Spacing="8">
                    <Label Text="Explore Cuisine" FontFamily="BeVietnamProBold" FontSize="24" TextColor="White" VerticalOptions="Center"/>
                    <Label Text="🍽️" FontSize="22" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Label Text="Discover unique flavors around you" FontFamily="BeVietnamPro" FontSize="14" TextColor="#FFE8D0" Margin="0,-8,0,0" />

                <!-- Search Bar -->
                <Border BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 24" StrokeThickness="0" Padding="16,4" Margin="0,8,0,0">
                    <Border.Shadow>
                        <Shadow Brush="#30000000" Offset="0,6" Radius="12" Opacity="1"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="🔍" FontSize="18" VerticalOptions="Center" Margin="0,0,10,0"/>
                        <Entry Grid.Column="1" Style="{StaticResource InputEntry}" Placeholder="What do you want to eat today?" Text="{Binding SearchQuery}" ReturnCommand="{Binding SearchCommand}" ReturnType="Search"/>
                        <Button Grid.Column="2" Text="✕" Command="{Binding RefreshCommand}" BackgroundColor="Transparent" TextColor="{StaticResource TextHint}" FontSize="14" Padding="8,0" HeightRequest="40" IsVisible="{Binding SearchQuery, Converter={StaticResource StringNotEmptyConverter}}"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </Border>

        <!-- ── CONTENT ── -->
        <Grid Grid.Row="1">
            <!-- LIST VIEW -->
            <RefreshView Command="{Binding RefreshCommand}"
                         IsRefreshing="{Binding IsLoading}"
                         RefreshColor="{StaticResource Primary}"
                         IsVisible="{Binding IsMapView, Converter={StaticResource BoolInverterConverter}}">
                <Grid>
                    <!-- Loading -->
                    <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <!-- Empty State -->
                    <VerticalStackLayout IsVisible="{Binding IsEmpty}" VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                        <Label Text="🔍" FontSize="56" HorizontalOptions="Center"/>
                        <Label Text="No results found" Style="{StaticResource TitleMedium}" HorizontalOptions="Center"/>
                        <Label Text="Try searching with a different keyword" Style="{StaticResource BodySmall}" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                    <!-- POI List -->
                    <CollectionView ItemsSource="{Binding FilteredPOIs}" SelectionMode="None" IsVisible="{Binding IsEmpty, Converter={StaticResource BoolInverterConverter}}" Margin="0,4">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="0"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:POIDto">
                                <Border BackgroundColor="{StaticResource Surface}" StrokeShape="RoundRectangle 24" StrokeThickness="0" Margin="20,10,20,16">
                                    <Border.Shadow>
                                        <Shadow Brush="#25000000" Offset="0,8" Radius="16" Opacity="1"/>
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:POIListViewModel}}, Path=NavigateToPOICommand}" CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <Grid RowDefinitions="200,Auto">
                                        <!-- Image -->
                                        <Image Grid.Row="0" Source="{Binding ImageUrl}" Aspect="AspectFill" HeightRequest="200">
                                            <Image.Clip>
                                                <RoundRectangleGeometry CornerRadius="24,24,0,0" Rect="0,0,10000,200"/>
                                            </Image.Clip>
                                        </Image>

                                        <!-- Gradient Image Overlay for better text readability -->
                                        <Border Grid.Row="0" StrokeShape="RoundRectangle 24,24,0,0" StrokeThickness="0" VerticalOptions="End" HeightRequest="100">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="Transparent" Offset="0" />
                                                    <GradientStop Color="#90000000" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>

                                        <!-- Audio Badge with Blur Feel -->
                                        <Border Grid.Row="0" BackgroundColor="#50000000" StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="12,6" HorizontalOptions="Start" VerticalOptions="Start" Margin="16,16,0,0">
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="🎧" FontSize="14" VerticalOptions="Center"/>
                                                <Label Text="Audio Guide" FontFamily="BeVietnamProMedium" FontSize="12" TextColor="White" VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </Border>

                                        <!-- Distance/Location Overlay directly on Image -->
                                        <HorizontalStackLayout Grid.Row="0" Spacing="4" HorizontalOptions="Start" VerticalOptions="End" Margin="16,0,0,12">
                                            <Label Text="📍" FontSize="14" TextColor="White" VerticalOptions="Center"/>
                                            <Label Text="{Binding Location}" FontFamily="BeVietnamProMedium" FontSize="13" TextColor="White" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1"/>
                                        </HorizontalStackLayout>

                                        <!-- Info Component -->
                                        <VerticalStackLayout Grid.Row="1" Padding="20,16,20,20" Spacing="8">
                                            <Label Text="{Binding Shop.Name}" FontFamily="BeVietnamProBold" FontSize="20" TextColor="{StaticResource TextPrimary}" LineBreakMode="TailTruncation" MaxLines="1"/>
                                            <Label Text="{Binding Shop.Description}" FontFamily="BeVietnamPro" FontSize="14" TextColor="{StaticResource TextSecondary}" LineBreakMode="TailTruncation" MaxLines="2"/>
                                            
                                            <!-- Play Audio Button -->
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                                                <Border Grid.Column="0" BackgroundColor="#FFF0E6" StrokeShape="RoundRectangle 14" StrokeThickness="0" Padding="14,10" HorizontalOptions="Start">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer 
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:POIListViewModel}}, Path=PlayAudioDirectCommand}" 
                                                            CommandParameter="{Binding .}"/>
                                                    </Border.GestureRecognizers>
                                                    <HorizontalStackLayout Spacing="8">
                                                        <Label Text="▶" FontSize="14" TextColor="{StaticResource Primary}" VerticalOptions="Center"/>
                                                        <Label Text="Listen Audio" FontFamily="BeVietnamProSemiBold" FontSize="14" TextColor="{StaticResource Primary}" VerticalOptions="Center"/>
                                                    </HorizontalStackLayout>
                                                </Border>

                                                <!-- Quick play circle button -->
                                                <Border Grid.Column="1"
                                                        BackgroundColor="{StaticResource Primary}" 
                                                        StrokeShape="RoundRectangle 22" 
                                                        StrokeThickness="0"
                                                        WidthRequest="44" HeightRequest="44"
                                                        HorizontalOptions="End"
                                                        VerticalOptions="Center">
                                                    <Border.Shadow>
                                                        <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="8" Opacity="0.3"/>
                                                    </Border.Shadow>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer 
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:POIListViewModel}}, Path=PlayAudioDirectCommand}" 
                                                            CommandParameter="{Binding .}"/>
                                                    </Border.GestureRecognizers>
                                                    <Label Text="🎧" FontSize="20" 
                                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                                </Border>
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.Footer>
                            <BoxView HeightRequest="80" Color="Transparent"/>
                        </CollectionView.Footer>
                    </CollectionView>
                </Grid>
            </RefreshView>

            <Grid IsVisible="{Binding IsMapView}">
                <WebView x:Name="MapWebView" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand" 
                         Navigating="MapWebView_Navigating"
                         Navigated="MapWebView_Navigated" />
            </Grid>

            <!-- PREMIUN FLOATING TOGGLE BUTTON -->
            <Border StrokeShape="RoundRectangle 28"
                    StrokeThickness="0"
                    Padding="20,14"
                    HorizontalOptions="Center"
                    VerticalOptions="End"
                    Margin="0,0,0,24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                        <GradientStop Color="{StaticResource PrimaryDark}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource PrimaryDark}" Offset="0,8" Radius="16" Opacity="0.4"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleViewCommand}"/>
                </Border.GestureRecognizers>
                <!-- When List View, Show "Map" -->
                <HorizontalStackLayout Spacing="8" IsVisible="{Binding IsMapView, Converter={StaticResource BoolInverterConverter}}">
                    <Label Text="🗺️" TextColor="White" FontSize="18" VerticalOptions="Center"/>
                    <Label Text="Map" TextColor="White" FontFamily="BeVietnamProBold" FontSize="15" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                
                <!-- When Map View, Show "List" -->
                <HorizontalStackLayout Spacing="8" IsVisible="{Binding IsMapView}">
                    <Label Text="📋" TextColor="White" FontSize="18" VerticalOptions="Center"/>
                    <Label Text="List" TextColor="White" FontFamily="BeVietnamProBold" FontSize="15" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>
        </Grid>
        <!-- 🤖 Floating Chatbot Bubble -->
        <Border WidthRequest="58"
                HeightRequest="58"
                StrokeShape="RoundRectangle 29"
                StrokeThickness="0"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,20,28">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF6B35" Offset="0.0" />
                    <GradientStop Color="#FF4500" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="#FF6B35" Offset="0,6" Radius="14" Opacity="0.5"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnChatbotTapped"/>
            </Border.GestureRecognizers>
            <Label Text="🤖"
                   FontSize="26"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontFamily="{x:Null}"/>
        </Border>
    </Grid>
</ContentPage>
