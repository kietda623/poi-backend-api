<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppUser.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AppUser.ViewModels"
    x:DataType="vm:LoginViewModel"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ── HEADER with Logo ── -->
            <Border StrokeThickness="0" Margin="0,-1,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0,0,40,40" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                        <GradientStop Color="{StaticResource PrimaryDark}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <VerticalStackLayout Padding="24,56,24,36" Spacing="10" HorizontalOptions="Center">
                    <Border StrokeShape="RoundRectangle 28"
                            StrokeThickness="0"
                            BackgroundColor="#20FFFFFF"
                            WidthRequest="96" HeightRequest="96"
                            HorizontalOptions="Center">
                        <Image Source="foodtour_logo.png"
                               WidthRequest="68" HeightRequest="68"
                               Aspect="AspectFit"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <Label Text="FoodTour"
                           FontSize="26"
                           FontFamily="{x:Null}"
                           TextColor="White"
                           HorizontalOptions="Center"/>
                    <Label Text="Audio Guide for Food Lovers"
                           FontSize="13"
                           FontFamily="{x:Null}"
                           TextColor="#CCFFFFFF"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- ── LOGIN FORM ── -->
            <VerticalStackLayout Padding="24,28,24,8" Spacing="18">

                <Label Text="Sign in to your account"
                       FontSize="20"
                       FontFamily="{x:Null}"
                       TextColor="{StaticResource TextPrimary}"/>

                <!-- Error -->
                <Border IsVisible="{Binding HasError}" BackgroundColor="#FEF2F2" Stroke="{StaticResource Error}" StrokeShape="RoundRectangle 12" StrokeThickness="1" Padding="12,10">
                    <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}" Style="{StaticResource BodySmall}" />
                </Border>

                <!-- Email -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Email" Style="{StaticResource TitleMedium}" />
                    <Border BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 14" StrokeThickness="1" Padding="14,2">
                        <Entry
                            x:Name="EmailEntry"
                            Text="{Binding Email}"
                            Keyboard="Email"
                            Placeholder="you@example.com"
                            Style="{StaticResource InputEntry}"
                            ReturnType="Next" />
                    </Border>
                </VerticalStackLayout>

                <!-- Password -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Password" Style="{StaticResource TitleMedium}" />
                    <Border BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 14" StrokeThickness="1" Padding="14,2">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry
                                Grid.Column="0"
                                Text="{Binding Password}"
                                Placeholder="Enter your password"
                                Style="{StaticResource InputEntry}"
                                IsPassword="{Binding IsPasswordVisible, Converter={StaticResource BoolInverterConverter}}"
                                ReturnType="Done"
                                ReturnCommand="{Binding LoginCommand}" />
                            <Button
                                Grid.Column="1"
                                Text="{Binding IsPasswordVisible, Converter={StaticResource EyeIconConverter}}"
                                Command="{Binding TogglePasswordVisibilityCommand}"
                                Style="{StaticResource IconButton}" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- ✅ BUTTON 1: Sign In -->
                <Border StrokeThickness="0" StrokeShape="RoundRectangle 16" Margin="0,4,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                            <GradientStop Color="{StaticResource PrimaryDark}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource Primary}" Offset="0,6" Radius="14" Opacity="0.35"/>
                    </Border.Shadow>
                    <Button
                        Text="Sign In"
                        Command="{Binding LoginCommand}"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="16"
                        FontFamily="{x:Null}"
                        HeightRequest="52"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource BoolInverterConverter}}" />
                </Border>

                <ActivityIndicator IsVisible="{Binding IsLoading}" IsRunning="{Binding IsLoading}" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- ── DIVIDER ── -->
            <Grid ColumnDefinitions="*,Auto,*" Padding="24,8,24,8">
                <BoxView Grid.Column="0" HeightRequest="1" Color="{StaticResource Border}" VerticalOptions="Center"/>
                <Label Grid.Column="1" Text="  or  " FontFamily="{x:Null}" FontSize="13" TextColor="{StaticResource TextHint}" VerticalOptions="Center"/>
                <BoxView Grid.Column="2" HeightRequest="1" Color="{StaticResource Border}" VerticalOptions="Center"/>
            </Grid>

            <!-- ── ALTERNATIVE OPTIONS ── -->
            <VerticalStackLayout Padding="24,8,24,24" Spacing="14">

                <!-- ✅ BUTTON 2: Sign Up -->
                <Border StrokeThickness="1.5"
                        Stroke="{StaticResource Primary}"
                        StrokeShape="RoundRectangle 16"
                        BackgroundColor="Transparent">
                    <Button
                        Text="Create an Account"
                        Command="{Binding NavigateToRegisterCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Primary}"
                        FontSize="16"
                        FontFamily="{x:Null}"
                        HeightRequest="52"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource BoolInverterConverter}}" />
                </Border>

                <!-- ✅ BUTTON 3: Continue as Guest -->
                <Border StrokeThickness="1"
                        Stroke="{StaticResource Border}"
                        StrokeShape="RoundRectangle 16"
                        BackgroundColor="{StaticResource Surface}">
                    <Button
                        Text="Continue as Guest"
                        Command="{Binding ContinueAsGuestCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource TextSecondary}"
                        FontSize="15"
                        FontFamily="{x:Null}"
                        HeightRequest="52"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource BoolInverterConverter}}" />
                </Border>

                <Label Text="Guest users can explore and purchase daily audio packages without an account."
                       FontSize="12"
                       FontFamily="{x:Null}"
                       TextColor="{StaticResource TextHint}"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"
                       Margin="0,-4,0,0"/>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
