<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppUser.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AppUser.ViewModels"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <Grid RowDefinitions="Auto,*,Auto" MinimumHeightRequest="600">

            <!-- ── TOP DECORATIVE AREA ── -->
            <Grid Grid.Row="0" HeightRequest="300">
                <Grid.Background>
                    <RadialGradientBrush Center="0.5,0.4" Radius="1.2">
                        <GradientStop Color="{StaticResource PrimaryLight}" Offset="0.0" />
                        <GradientStop Color="{StaticResource Primary}" Offset="0.6" />
                        <GradientStop Color="{StaticResource PrimaryDark}" Offset="1.0" />
                    </RadialGradientBrush>
                </Grid.Background>

                <!-- Decorative elements with Lamination -->
                <Ellipse Fill="{StaticResource LaminationGradient}" 
                         WidthRequest="400" HeightRequest="400"
                         HorizontalOptions="Center" VerticalOptions="Center"
                         Margin="0,-150,0,0"/>

                <!-- Logo & Title -->
                <VerticalStackLayout
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Spacing="16" Padding="0,20,0,0">

                    <!-- Food Icon (Vector) -->
                    <Border BackgroundColor="White"
                            StrokeShape="RoundRectangle 24"
                            WidthRequest="90" HeightRequest="90"
                            StrokeThickness="0"
                            HorizontalOptions="Center">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.1" />
                        </Border.Shadow>
                        <Label Text="🍔" 
                               FontFamily="{x:Null}"
                               FontSize="54"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <Label Text="FoodTour POI"
                           Style="{StaticResource HeadlineMedium}"
                           TextColor="White"
                           HorizontalOptions="Center"
                           FontSize="28"/>

                    <Label Text="Discover local cuisine"
                           Style="{StaticResource BodyMedium}"
                           TextColor="#D0FFFFFF"
                           HorizontalOptions="Center"
                           FontFamily="BeVietnamProMedium"/>
                </VerticalStackLayout>
            </Grid>

            <!-- ── LOGIN FORM CARD ── -->
            <Border Grid.Row="1"
                    BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 32,32,0,0"
                    StrokeThickness="0"
                    Margin="0,-32,0,0"
                    Padding="32,40,32,20">

                <VerticalStackLayout Spacing="0">

                    <Label Text="Welcome back"
                           Style="{StaticResource HeadlineSmall}"
                           Margin="0,0,0,6"/>

                    <Label Text="Sign in to start your journey"
                           Style="{StaticResource BodyMedium}"
                           TextColor="{StaticResource TextSecondary}"
                           Margin="0,0,0,32"/>

                    <!-- Error Banner -->
                    <Border BackgroundColor="#FFF1F2"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="0"
                            Padding="16,12"
                            Margin="0,0,0,24"
                            IsVisible="{Binding HasError}">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="⚠️" FontFamily="{x:Null}" FontSize="16" 
                                   TextColor="{StaticResource Error}" VerticalOptions="Center"/>
                            <Label Text="{Binding ErrorMessage}"
                                   Style="{StaticResource BodySmall}"
                                   TextColor="{StaticResource Error}"
                                   VerticalOptions="Center"
                                   FontFamily="BeVietnamProMedium"/>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Email Field -->
                    <Label Text="Email" Style="{StaticResource TitleMedium}" Margin="0,0,0,8"/>
                    <Border BackgroundColor="{StaticResource SurfaceVariant}"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="0"
                            Padding="18,2"
                            Margin="0,0,0,20">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry Grid.Column="0"
                                   x:Name="EmailEntry"
                                   Style="{StaticResource InputEntry}"
                                   Placeholder="example@mail.com"
                                   Text="{Binding Email}"
                                   Keyboard="Email"
                                   ReturnType="Next"/>
                            <Label Grid.Column="1" Text="{StaticResource IconEmail}" 
                                   FontFamily="{x:Null}" FontSize="18"
                                   TextColor="{StaticResource TextHint}"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <!-- Password Field -->
                    <Label Text="Password" Style="{StaticResource TitleMedium}" Margin="0,0,0,8"/>
                    <Border BackgroundColor="{StaticResource SurfaceVariant}"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="0"
                            Padding="18,2"
                            Margin="0,0,0,12">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry Grid.Column="0"
                                   Style="{StaticResource InputEntry}"
                                   Placeholder="••••••••"
                                   Text="{Binding Password}"
                                   IsPassword="{Binding IsPasswordVisible, Converter={StaticResource BoolInverterConverter}}"
                                   ReturnType="Done"
                                   ReturnCommand="{Binding LoginCommand}"/>
                            <Button Grid.Column="1"
                                    Text="{Binding IsPasswordVisible, Converter={StaticResource EyeIconConverter}}" 
                                    Command="{Binding TogglePasswordVisibilityCommand}"
                                    Style="{StaticResource IconButton}"
                                    TextColor="{StaticResource TextHint}"
                                    FontSize="18"/>
                        </Grid>
                    </Border>

                    <!-- Login Button -->
                    <Button Text="Sign In"
                            Command="{Binding LoginCommand}"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource BoolInverterConverter}}"
                            HorizontalOptions="Fill"/>

                    <!-- Loading Indicator -->
                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                       IsVisible="{Binding IsLoading}"
                                       HorizontalOptions="Center"
                                       Margin="0,16,0,0"/>

                </VerticalStackLayout>
            </Border>

            <!-- ── FOOTER ── -->
            <VerticalStackLayout Grid.Row="2"
                                 Padding="28,12"
                                 BackgroundColor="{StaticResource Surface}">
                
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,0,0,16">
                    <Label Text="Don't have an account?" Style="{StaticResource BodyMedium}" />
                    <Label Text="Sign Up" TextColor="{StaticResource Primary}" Style="{StaticResource TitleMedium}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToRegisterCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <Label Text="© 2026 FoodTour POI · Explore culinary delights"
                       Style="{StaticResource LabelCaption}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

        </Grid>
    </ScrollView>
</ContentPage>
