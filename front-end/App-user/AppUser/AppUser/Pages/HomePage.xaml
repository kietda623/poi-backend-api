<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppUser.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AppUser.ViewModels"
    xmlns:models="clr-namespace:AppUser.Models"
    Title="Trang chủ"
    BackgroundColor="{StaticResource Background}">

    <RefreshView Command="{Binding LoadFeaturedPOIsCommand}"
                 IsRefreshing="{Binding IsLoading}"
                 RefreshColor="{StaticResource Primary}">

        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <Grid Padding="20,24,20,44">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource Primary}" Offset="0.1" />
                            <GradientStop Color="#6366F1" Offset="1.0" />
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,24">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="{Binding GreetingText}"
                                   Style="{StaticResource BodyMedium}"
                                   TextColor="#CCFFFFFF"
                                   FontFamily="BeVietnamProMedium"/>
                            <Label Text="{Binding PageTitle}"
                                   Style="{StaticResource HeadlineMedium}"
                                   TextColor="White"
                                   FontSize="26"/>
                        </VerticalStackLayout>

                        <Border Grid.Column="1"
                                BackgroundColor="#20FFFFFF"
                                StrokeShape="RoundRectangle 20"
                                StrokeThickness="0.8"
                                Stroke="#40FFFFFF"
                                Padding="14,8"
                                VerticalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangeLanguageCommand}"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="🌐" FontFamily="{x:Null}" TextColor="White" FontSize="14" VerticalOptions="Center"/>
                                <Label Text="{Binding CurrentLanguage}"
                                        TextColor="White"
                                        FontFamily="BeVietnamProBold"
                                        FontSize="14"
                                        VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            Style="{StaticResource GlassBorder}"
                            Padding="20,12"
                            Margin="0,0,0,-24"
                            HeightRequest="64">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,12" Radius="24" Opacity="0.15"/>
                        </Border.Shadow>
                        <HorizontalStackLayout Spacing="14">
                            <Label Text="{StaticResource IconSearch}" 
                                   Style="{StaticResource IconLabel}"
                                   TextColor="White"
                                   FontSize="18" 
                                   VerticalOptions="Center"/>
                            <Label Text="{Binding SearchPlaceholder}"
                                   Style="{StaticResource BodyMedium}"
                                   TextColor="#E0FFFFFF"
                                   VerticalOptions="Center"
                                   FontSize="15"
                                   FontFamily="{x:Null}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateToAllPOIsCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

                <VerticalStackLayout Padding="20,16,20,0" Spacing="20">
                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                        <Label Grid.Column="0"
                               Text="{Binding FeaturedSectionTitle}"
                               Style="{StaticResource TitleLarge}"
                               FontSize="19"/>
                        <Label Grid.Column="1"
                               Text="{Binding SeeAllText}"
                               Style="{StaticResource BodySmall}"
                               TextColor="{StaticResource Primary}"
                               FontFamily="BeVietnamProBold"
                               VerticalOptions="Center"
                               Margin="0,0,4,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding NavigateToAllPOIsCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                                Margin="-20,0"
                                IsVisible="{Binding IsLoading, Converter={StaticResource BoolInverterConverter}}">
                        <HorizontalStackLayout x:Name="FeaturedList"
                                               Spacing="18" Padding="20,10">
                            <BindableLayout.ItemsSource>
                                <Binding Path="FeaturedPOIs"/>
                            </BindableLayout.ItemsSource>
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:POIDto">
                                    <Border Style="{StaticResource PremiumBorder}"
                                            WidthRequest="260"
                                            HeightRequest="340"
                                            Padding="0">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=NavigateToPOICommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>

                                        <Grid>
                                            <Image Source="{Binding ImageUrl}"
                                                   Aspect="AspectFill"
                                                   HeightRequest="340"/>

                                            <BoxView VerticalOptions="End" HeightRequest="160">
                                                <BoxView.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="Transparent" Offset="0" />
                                                        <GradientStop Color="#E00F172A" Offset="1" />
                                                    </LinearGradientBrush>
                                                </BoxView.Background>
                                            </BoxView>

                                            <Border BackgroundColor="{StaticResource Accent}"
                                                    StrokeShape="RoundRectangle 10"
                                                    StrokeThickness="0"
                                                    Padding="10,5"
                                                    HorizontalOptions="End"
                                                    VerticalOptions="Start"
                                                    Margin="14">
                                                <HorizontalStackLayout Spacing="4">
                                                    <Label Text="🔊" FontFamily="{x:Null}" FontSize="10" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center"/>
                                                    <Label Text="VOX"
                                                           Style="{StaticResource LabelCaption}"
                                                           TextColor="{StaticResource TextPrimary}"
                                                           FontFamily="BeVietnamProBold"
                                                           FontSize="10"
                                                           VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                            </Border>

                                            <Border BackgroundColor="White"
                                                    StrokeShape="RoundRectangle 28"
                                                    StrokeThickness="0"
                                                    WidthRequest="54" HeightRequest="54"
                                                    HorizontalOptions="End"
                                                    VerticalOptions="End"
                                                    Margin="0,0,18,80">
                                                <Border.Shadow>
                                                    <Shadow Brush="Black" Offset="0,6" Radius="12" Opacity="0.2"/>
                                                </Border.Shadow>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=PlayAudioDirectCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="{StaticResource IconPlay}" 
                                                       FontFamily="{x:Null}"
                                                       FontSize="20" 
                                                       TextColor="{StaticResource Primary}"
                                                       HorizontalOptions="Center" VerticalOptions="Center"
                                                       Margin="4,0,0,0"/>
                                            </Border>

                                            <VerticalStackLayout VerticalOptions="End" Padding="18" Spacing="6">
                                                <Label Text="{Binding Shop.Name}"
                                                       Style="{StaticResource TitleLarge}"
                                                       TextColor="White"
                                                       FontSize="19"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1"/>
                                                <HorizontalStackLayout Spacing="8">
                                                    <Label Text="{StaticResource IconMapMarker}" 
                                                           FontFamily="{x:Null}" 
                                                           FontSize="12"
                                                           TextColor="#CCFFFFFF"
                                                           VerticalOptions="Center"/>
                                                    <Label Text="{Binding Location}"
                                                           Style="{StaticResource BodySmall}"
                                                           TextColor="#CCFFFFFF"
                                                           FontSize="13"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="1"
                                                           VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                       IsVisible="{Binding IsLoading}"
                                       HeightRequest="100"
                                       Color="{StaticResource Primary}"
                                       HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Padding="20,24,20,20" Spacing="16">
                    <Label Text="{Binding DiscoverMoreTitle}"
                           Style="{StaticResource TitleLarge}"
                           FontSize="18"/>

                    <CollectionView ItemsSource="{Binding FeaturedPOIs}"
                                    SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:POIDto">
                                <Border Style="{StaticResource PremiumBorder}"
                                        Padding="8">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=NavigateToPOICommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="100,*" HeightRequest="100" ColumnSpacing="16">
                                        <Border Grid.Column="0"
                                                StrokeShape="RoundRectangle 14"
                                                StrokeThickness="0">
                                            <Image Source="{Binding ImageUrl}"
                                                   Aspect="AspectFill"
                                                   HeightRequest="100"
                                                   WidthRequest="100"/>
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="6"
                                                             VerticalOptions="Center">
                                            <Label Text="{Binding Shop.Name}"
                                                   Style="{StaticResource TitleLarge}"
                                                   FontSize="16"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"/>
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="📍" FontSize="12" Opacity="0.7"/>
                                                <Label Text="{Binding Location}"
                                                       Style="{StaticResource BodyMedium}"
                                                       FontSize="13"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1"/>
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout Spacing="6" Margin="0,2,0,0">
                                                <Border BackgroundColor="{StaticResource Primary}"
                                                        StrokeShape="RoundRectangle 12"
                                                        StrokeThickness="0"
                                                        Padding="12,6"
                                                        HorizontalOptions="Start">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=PlayAudioDirectCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                    </Border.GestureRecognizers>
                                                    <HorizontalStackLayout Spacing="6">
                                                        <Label Text="▶" FontSize="11" TextColor="White" VerticalOptions="Center"/>
                                                        <Label Text="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=ListenNowText}"
                                                               Style="{StaticResource LabelCaption}"
                                                               TextColor="White"
                                                               FontFamily="BeVietnamProBold"
                                                               VerticalOptions="Center"/>
                                                    </HorizontalStackLayout>
                                                </Border>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <Label Grid.Column="1"
                                               Text="〉"
                                               TextColor="{StaticResource Border}"
                                               FontSize="18"
                                               HorizontalOptions="End"
                                               VerticalOptions="Center"
                                               Margin="0,0,8,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
