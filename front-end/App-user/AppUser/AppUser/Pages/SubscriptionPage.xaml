<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppUser.Pages.SubscriptionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:model="clr-namespace:AppUser.Models"
    xmlns:vm="clr-namespace:AppUser.ViewModels"
    x:Name="PageRoot"
    x:DataType="vm:SubscriptionViewModel"
    Title="{Binding Title}"
    BackgroundColor="{StaticResource Background}">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="16">
                <Label
                    FontFamily="{x:Null}"
                    FontSize="24"
                    Text="{Binding PageHeading}"
                    TextColor="{StaticResource TextPrimary}" />

                <Border
                    BackgroundColor="#EEF2FF"
                    IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
                    Padding="14"
                    StrokeShape="RoundRectangle 18"
                    StrokeThickness="0">
                    <Label
                        FontFamily="{x:Null}"
                        Text="{Binding StatusMessage}"
                        TextColor="{StaticResource Primary}" />
                </Border>

                <Border
                    BackgroundColor="{StaticResource Surface}"
                    Padding="16"
                    StrokeShape="RoundRectangle 18"
                    StrokeThickness="0">
                    <VerticalStackLayout Spacing="8">
                        <Label
                            FontFamily="{x:Null}"
                            FontSize="18"
                            Text="{Binding CurrentPackageHeading}"
                            TextColor="{StaticResource TextPrimary}" />

                        <VerticalStackLayout
                            IsVisible="{Binding Current.HasSubscription}"
                            Spacing="8">
                            <Label
                                FontFamily="{x:Null}"
                                FontSize="17"
                                Text="{Binding Current.Subscription.PackageName}"
                                TextColor="{StaticResource TextPrimary}" />
                            <Label
                                FontFamily="{x:Null}"
                                Text="{Binding CurrentStatusDisplay}"
                                TextColor="{StaticResource Primary}" />
                            <Label
                                FontFamily="{x:Null}"
                                Text="{Binding CurrentExpiryDisplay}"
                                TextColor="{StaticResource TextSecondary}" />

                            <ActivityIndicator
                                Color="{StaticResource Primary}"
                                IsRunning="{Binding IsPaymentChecking}"
                                IsVisible="{Binding IsPaymentChecking}"
                                HorizontalOptions="Start" />

                            <Label
                                FontFamily="{x:Null}"
                                IsVisible="{Binding IsPaymentChecking}"
                                Text="{Binding PaymentCheckingMessage}"
                                TextColor="{StaticResource TextSecondary}" />

                            <Button
                                Command="{Binding ContinuePaymentCommand}"
                                FontFamily="{x:Null}"
                                IsVisible="{Binding Current.Subscription.CheckoutUrl, Converter={StaticResource StringNotEmptyConverter}}"
                                Style="{StaticResource PrimaryButton}"
                                Text="{Binding ContinuePaymentText}" />

                            <Button
                                Command="{Binding CancelCurrentCommand}"
                                FontFamily="{x:Null}"
                                Style="{StaticResource SecondaryButton}"
                                Text="{Binding CancelPackageText}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout
                            IsVisible="{Binding Current.HasSubscription, Converter={StaticResource BoolInverterConverter}}"
                            Spacing="8">
                            <Label
                                FontFamily="{x:Null}"
                                Text="{Binding NoActivePackageText}"
                                TextColor="{StaticResource TextSecondary}" />
                            <Button
                                Command="{Binding ReloadCommand}"
                                FontFamily="{x:Null}"
                                Style="{StaticResource SecondaryButton}"
                                Text="{Binding ReloadText}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Label
                    FontFamily="{x:Null}"
                    FontSize="18"
                    Text="{Binding ChoosePackageHeading}"
                    TextColor="{StaticResource TextPrimary}" />

                <Label
                    FontFamily="{x:Null}"
                    IsVisible="{Binding Packages.Count, Converter={StaticResource IntIsZeroConverter}}"
                    Text="{Binding EmptyPackagesText}"
                    TextColor="{StaticResource TextSecondary}" />

                <VerticalStackLayout
                    BindableLayout.ItemsSource="{Binding Packages}"
                    Spacing="14">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="model:AppServicePackageDto">
                            <Border
                                BackgroundColor="{StaticResource Surface}"
                                Padding="16"
                                StrokeShape="RoundRectangle 18"
                                StrokeThickness="0">
                                <VerticalStackLayout Spacing="12">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label
                                            FontFamily="{x:Null}"
                                            FontSize="18"
                                            Text="{Binding Name}"
                                            TextColor="{StaticResource TextPrimary}" />
                                    </HorizontalStackLayout>

                                    <Label
                                        FontFamily="{x:Null}"
                                        Text="{Binding Description}"
                                        TextColor="{StaticResource TextSecondary}" />

                                    <Border
                                        BackgroundColor="#F8FAFC"
                                        Padding="12"
                                        Stroke="{StaticResource Border}"
                                        StrokeShape="RoundRectangle 14">
                                        <VerticalStackLayout Spacing="4">
                                            <Label
                                                FontFamily="{x:Null}"
                                                Text="{Binding DisplayLabel}"
                                                TextColor="{StaticResource TextSecondary}" />
                                            <Label
                                                FontFamily="{x:Null}"
                                                FontSize="18"
                                                Text="{Binding DisplayPrice, StringFormat='VND {0:N0}'}"
                                                TextColor="{StaticResource TextPrimary}" />
                                        </VerticalStackLayout>
                                    </Border>

                                    <VerticalStackLayout
                                        BindableLayout.ItemsSource="{Binding Features}"
                                        Spacing="6">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Label
                                                    FontFamily="{x:Null}"
                                                    Text="{Binding ., StringFormat='- {0}'}"
                                                    TextColor="{StaticResource TextSecondary}" />
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>

                                    <Button
                                        Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.SubscribeMonthlyCommand}"
                                        CommandParameter="{Binding .}"
                                        FontFamily="{x:Null}"
                                        Style="{StaticResource PrimaryButton}"
                                        Text="{Binding DisplayLabel, StringFormat='Subscribe {0}'}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <Grid
            BackgroundColor="#990F172A"
            InputTransparent="False"
            IsVisible="{Binding IsQrVisible}"
            Padding="12"
            ZIndex="10">
            <Border
                BackgroundColor="White"
                HorizontalOptions="Center"
                MaximumHeightRequest="{Binding QrDialogMaxHeight}"
                Padding="16"
                StrokeShape="RoundRectangle 24"
                StrokeThickness="0"
                VerticalOptions="Center"
                WidthRequest="{Binding QrDialogWidth}">
                <ScrollView>
                    <VerticalStackLayout Spacing="14">
                        <Label
                            FontFamily="{x:Null}"
                            FontSize="20"
                            HorizontalTextAlignment="Center"
                            Text="{Binding QrDialogTitle}"
                            TextColor="{StaticResource TextPrimary}" />

                        <Label
                            HorizontalTextAlignment="Center"
                            LineBreakMode="WordWrap"
                            Text="{Binding PendingCheckoutTitle}"
                            TextColor="{StaticResource TextSecondary}" />

                        <Image
                            HeightRequest="{Binding QrImageSize}"
                            HorizontalOptions="Center"
                            IsVisible="{Binding ShowQrImage}"
                            Source="{Binding QrImageUrl}"
                            WidthRequest="{Binding QrImageSize}" />

                        <Label
                            HorizontalTextAlignment="Center"
                            LineBreakMode="WordWrap"
                            Text="{Binding QrDialogHint}"
                            TextColor="{StaticResource TextSecondary}" />

                        <ActivityIndicator
                            Color="{StaticResource Primary}"
                            HorizontalOptions="Center"
                            IsRunning="{Binding IsPaymentChecking}"
                            IsVisible="{Binding IsPaymentChecking}" />

                        <Label
                            HorizontalTextAlignment="Center"
                            IsVisible="{Binding IsPaymentChecking}"
                            LineBreakMode="WordWrap"
                            Text="{Binding PaymentCheckingMessage}"
                            TextColor="{StaticResource TextSecondary}" />

                        <Button
                            Command="{Binding CloseQrCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Text="{Binding CloseQrText}" />
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
