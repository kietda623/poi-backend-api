<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppUser.Pages.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AppUser.ViewModels"
    x:DataType="vm:RegisterViewModel"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="24,48,24,24" Spacing="16">
            <Button Text="Back to Sign In" Style="{StaticResource OutlineButton}" Command="{Binding GoBackToLoginCommand}" />
            <Label Text="Create your account" Style="{StaticResource HeadlineMedium}" />
            <Label Text="Set up your profile to save favorites and sync your journey." Style="{StaticResource BodyMedium}" />

            <Border IsVisible="{Binding HasError}" BackgroundColor="#FEF2F2" Stroke="{StaticResource Error}" StrokeShape="RoundRectangle 12" StrokeThickness="1" Padding="12,10">
                <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}" Style="{StaticResource BodySmall}" />
            </Border>

            <VerticalStackLayout Spacing="8">
                <Label Text="Full name" Style="{StaticResource TitleMedium}" />
                <Border BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 14" StrokeThickness="1" Padding="14,2">
                    <Entry Text="{Binding FullName}" Placeholder="Jane Doe" Style="{StaticResource InputEntry}" ReturnType="Next" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Label Text="Email" Style="{StaticResource TitleMedium}" />
                <Border BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 14" StrokeThickness="1" Padding="14,2">
                    <Entry Text="{Binding Email}" Keyboard="Email" Placeholder="you@example.com" Style="{StaticResource InputEntry}" ReturnType="Next" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Label Text="Password" Style="{StaticResource TitleMedium}" />
                <Border BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 14" StrokeThickness="1" Padding="14,2">
                    <Grid ColumnDefinitions="*,Auto">
                        <Entry
                            Grid.Column="0"
                            Text="{Binding Password}"
                            IsPassword="{Binding IsPasswordVisible, Converter={StaticResource BoolInverterConverter}}"
                            Placeholder="At least 6 characters"
                            Style="{StaticResource InputEntry}"
                            ReturnType="Next" />
                        <Button Grid.Column="1" Text="{Binding IsPasswordVisible, Converter={StaticResource EyeIconConverter}}" Command="{Binding TogglePasswordVisibilityCommand}" Style="{StaticResource IconButton}" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Label Text="Confirm password" Style="{StaticResource TitleMedium}" />
                <Border BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 14" StrokeThickness="1" Padding="14,2">
                    <Entry
                        Text="{Binding ConfirmPassword}"
                        IsPassword="{Binding IsPasswordVisible, Converter={StaticResource BoolInverterConverter}}"
                        Placeholder="Enter password again"
                        Style="{StaticResource InputEntry}"
                        ReturnType="Done"
                        ReturnCommand="{Binding RegisterCommand}" />
                </Border>
            </VerticalStackLayout>

            <Button Text="Create Account" Command="{Binding RegisterCommand}" Style="{StaticResource PrimaryButton}" IsEnabled="{Binding IsLoading, Converter={StaticResource BoolInverterConverter}}" />
            <ActivityIndicator IsVisible="{Binding IsLoading}" IsRunning="{Binding IsLoading}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
