<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppUser.Pages.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AppUser.ViewModels"
    xmlns:models="clr-namespace:AppUser.Models"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Title="Hồ sơ"
    BackgroundColor="{StaticResource Background}">

    <Shell.TitleView>
        <Label Text="{Binding PageTitle}"
               FontFamily="BeVietnamProBold"
               FontSize="18"
               TextColor="White"
               VerticalOptions="Center"/>
    </Shell.TitleView>

    <!-- Root Grid for floating chatbot bubble -->
    <Grid>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <Border StrokeThickness="0" Margin="0,-20,0,0" Padding="24,60,24,56">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{StaticResource Primary}" Offset="0" />
                        <GradientStop Color="{StaticResource PrimaryDark}" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <VerticalStackLayout Spacing="16" HorizontalOptions="Fill">

                    <Border BackgroundColor="White"
                            StrokeShape="RoundRectangle 50"
                            StrokeThickness="4"
                            Stroke="#60FFFFFF"
                            WidthRequest="100" HeightRequest="100"
                            HorizontalOptions="Center">
                        <Border.Shadow>
                            <Shadow Brush="#40000000" Offset="0,8" Radius="15" Opacity="0.5"/>
                        </Border.Shadow>
                        <Label Text="😋"
                               FontSize="54"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <!-- Khi là Guest: hiện 'Khách tham quan' -->
                        <Label Text="{Binding CurrentUser.FullName}"
                               IsVisible="{Binding IsGuest, Converter={StaticResource BoolInverterConverter}}"
                               Style="{StaticResource HeadlineSmall}"
                               TextColor="White"
                               FontSize="22"
                               HorizontalOptions="Center"/>
                        <Label Text="{Binding CurrentUser.Email}"
                               IsVisible="{Binding IsGuest, Converter={StaticResource BoolInverterConverter}}"
                               Style="{StaticResource BodyMedium}"
                               TextColor="#CCFFFFFF"
                               HorizontalOptions="Center"
                               FontFamily="BeVietnamPro"/>

                        <!-- Guest mode header -->
                        <Label Text="Khách tham quan"
                               IsVisible="{Binding IsGuest}"
                               Style="{StaticResource HeadlineSmall}"
                               TextColor="White"
                               FontSize="22"
                               HorizontalOptions="Center"/>
                        <Label Text="{Binding GuestMessage}"
                               IsVisible="{Binding IsGuest}"
                               Style="{StaticResource BodyMedium}"
                               TextColor="#CCFFFFFF"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               FontFamily="BeVietnamPro"/>
                    </VerticalStackLayout>

                    <!-- Nút Edit Profile (chỉ cho User) -->
                    <Button Text="{Binding EditProfileText}"
                            Command="{Binding GoToEditProfileCommand}"
                            IsVisible="{Binding IsGuest, Converter={StaticResource BoolInverterConverter}}"
                            BackgroundColor="#20FFFFFF"
                            TextColor="White"
                            CornerRadius="20"
                            HeightRequest="42"
                            HorizontalOptions="Center"
                            Padding="20,0"
                            FontFamily="BeVietnamProSemiBold"
                            FontSize="13"
                            Margin="0,4,0,0"/>

                    <!-- Nút Đăng nhập / Đăng ký (chỉ cho Guest) -->
                    <Button Text="{Binding LoginButtonText}"
                            Command="{Binding GoToLoginCommand}"
                            IsVisible="{Binding IsGuest}"
                            BackgroundColor="#FF6B35"
                            TextColor="White"
                            CornerRadius="20"
                            HeightRequest="42"
                            HorizontalOptions="Center"
                            Padding="20,0"
                            FontFamily="BeVietnamProSemiBold"
                            FontSize="14"
                            Margin="0,4,0,0"/>

                    <Border BackgroundColor="#30FFFFFF"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0"
                            Padding="12,5"
                            HorizontalOptions="Center">
                        <Label Text="{Binding FoodieBadgeText}"
                               Style="{StaticResource LabelCaption}"
                               TextColor="White"
                               FontFamily="BeVietnamProBold"
                               FontSize="10"
                               CharacterSpacing="1"/>
                    </Border>

                    <Grid ColumnDefinitions="*,*" HorizontalOptions="Fill" Margin="0,12,0,0" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="#15FFFFFF"
                                StrokeShape="RoundRectangle 16"
                                StrokeThickness="0"
                                Padding="12,16">
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding TotalListened}"
                                       Style="{StaticResource HeadlineMedium}"
                                       TextColor="White"
                                       FontSize="28"
                                       HorizontalOptions="Center"/>
                                <Label Text="{Binding TotalExploredLabel}"
                                       Style="{StaticResource LabelCaption}"
                                       TextColor="#90FFFFFF"
                                       HorizontalOptions="Center"
                                       FontFamily="BeVietnamProMedium"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                BackgroundColor="#15FFFFFF"
                                StrokeShape="RoundRectangle 16"
                                StrokeThickness="0"
                                Padding="12,16">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangeLanguageCommand}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding CurrentLanguageDisplay}"
                                       Style="{StaticResource TitleLarge}"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       FontSize="18"
                                       FontFamily="BeVietnamProBold"/>
                                <Label Text="{Binding CurrentLanguageLabel}"
                                       Style="{StaticResource LabelCaption}"
                                       TextColor="#90FFFFFF"
                                       HorizontalOptions="Center"
                                       FontFamily="BeVietnamProMedium"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{StaticResource Background}"
                    StrokeShape="RoundRectangle 30,30,0,0"
                    StrokeThickness="0"
                    Margin="0,-30,0,0"
                    Padding="20,32,20,16">

                <VerticalStackLayout Spacing="24">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{Binding SettingsTitle}"
                               Style="{StaticResource TitleLarge}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="18"/>

                        <Border Style="{StaticResource PremiumBorder}"
                                Padding="16,14">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ChangeLanguageCommand}"/>
                                </Grid.GestureRecognizers>
                                <Border Grid.Column="0"
                                        BackgroundColor="{StaticResource SurfaceVariant}"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="0"
                                        WidthRequest="44" HeightRequest="44"
                                        Margin="0,0,16,0">
                                    <Label Text="🌐" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding NarrationLanguageTitle}"
                                           Style="{StaticResource TitleMedium}"
                                           TextColor="{StaticResource TextPrimary}"
                                           FontSize="15"/>
                                    <Label Text="{Binding CurrentLanguageDisplay}"
                                           Style="{StaticResource BodySmall}"
                                           TextColor="{StaticResource Primary}"
                                           FontFamily="BeVietnamProSemiBold"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="〉" FontSize="18" VerticalOptions="Center" TextColor="{StaticResource Border}"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource PremiumBorder}"
                                Padding="16,14">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding GoToSubscriptionPackagesCommand}"/>
                                </Grid.GestureRecognizers>
                                <Border Grid.Column="0"
                                        BackgroundColor="{StaticResource SurfaceVariant}"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="0"
                                        WidthRequest="44" HeightRequest="44"
                                        Margin="0,0,16,0">
                                    <Label Text="🎧" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding AudioPackageTitle}"
                                           Style="{StaticResource TitleMedium}"
                                           TextColor="{StaticResource TextPrimary}"
                                           FontSize="15"/>
                                    <Label Text="PayOS"
                                           Style="{StaticResource BodySmall}"
                                           TextColor="{StaticResource Primary}"
                                           FontFamily="BeVietnamProSemiBold"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="〉" FontSize="18" VerticalOptions="Center" TextColor="{StaticResource Border}"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="16">
                        <Label Text="{Binding HistoryTitle}"
                               Style="{StaticResource TitleLarge}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="18"/>

                        <Border Style="{StaticResource PremiumBorder}"
                                Padding="32,40"
                                IsVisible="{Binding ListenHistory.Count, Converter={StaticResource IntIsZeroConverter}}">
                            <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                                <Label Text="🧭" FontSize="48" HorizontalOptions="Center"/>
                                <Label Text="{Binding EmptyHistoryTitle}"
                                       Style="{StaticResource TitleLarge}"
                                       TextColor="{StaticResource TextPrimary}"
                                       HorizontalOptions="Center"/>
                                <Label Text="{Binding EmptyHistoryMessage}"
                                       Style="{StaticResource BodyMedium}"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       FontFamily="BeVietnamPro"/>
                            </VerticalStackLayout>
                        </Border>

                        <CollectionView ItemsSource="{Binding ListenHistory}"
                                        SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource PremiumBorder}"
                                            Padding="12">
                                        <Grid ColumnDefinitions="70,*,Auto" ColumnSpacing="16">
                                            <Border Grid.Column="0"
                                                    StrokeShape="RoundRectangle 12"
                                                    StrokeThickness="0"
                                                    WidthRequest="70" HeightRequest="70">
                                                <Image Source="{Binding POI.ImageUrl}"
                                                       Aspect="AspectFill"/>
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 VerticalOptions="Center"
                                                                 Spacing="4">
                                                <Label Text="{Binding POI.Shop.Name}"
                                                       Style="{StaticResource TitleMedium}"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1"/>
                                                <HorizontalStackLayout Spacing="6">
                                                    <Label Text="📍" FontSize="12" Opacity="0.7"/>
                                                    <Label Text="{Binding POI.Location}"
                                                           Style="{StaticResource BodySmall}"
                                                           TextColor="{StaticResource TextSecondary}"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="1"
                                                           FontFamily="BeVietnamPro"/>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>

                                            <Label Grid.Column="2"
                                                   Text="〉"
                                                   TextColor="{StaticResource Border}"
                                                   FontSize="20"
                                                   VerticalOptions="Center"
                                                   Margin="0,0,8,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Nút Logout (chỉ cho User đã đăng nhập) -->
            <Button Text="{Binding LogoutButtonText}"
                    Command="{Binding LogoutCommand}"
                    IsVisible="{Binding IsGuest, Converter={StaticResource BoolInverterConverter}}"
                    TextColor="{StaticResource Primary}"
                    BackgroundColor="{StaticResource SurfaceVariant}"
                    CornerRadius="16"
                    HeightRequest="56"
                    FontFamily="BeVietnamProBold"
                    FontSize="15"
                    Margin="20,8,20,40"
                    HorizontalOptions="Fill"/>

            <!-- Nút Đăng nhập (cho Guest ở cuối trang) -->
            <Button Text="{Binding LoginButtonText}"
                    Command="{Binding GoToLoginCommand}"
                    IsVisible="{Binding IsGuest}"
                    TextColor="White"
                    BackgroundColor="{StaticResource Primary}"
                    CornerRadius="16"
                    HeightRequest="56"
                    FontFamily="BeVietnamProBold"
                    FontSize="15"
                    Margin="20,8,20,40"
                    HorizontalOptions="Fill"/>

        </VerticalStackLayout>
    </ScrollView>

        <!-- 🤖 Floating Chatbot Bubble -->
        <Border WidthRequest="58"
                HeightRequest="58"
                StrokeShape="RoundRectangle 29"
                StrokeThickness="0"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,20,28">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF6B35" Offset="0.0" />
                    <GradientStop Color="#FF4500" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="#FF6B35" Offset="0,6" Radius="14" Opacity="0.5"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnChatbotTapped"/>
            </Border.GestureRecognizers>
            <Label Text="🤖"
                   FontSize="26"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontFamily="{x:Null}"/>
        </Border>

    </Grid>
