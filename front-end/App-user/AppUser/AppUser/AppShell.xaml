<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AppUser.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:AppUser.Pages"
    Shell.BackgroundColor="{StaticResource Primary}"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White"
    Shell.UnselectedColor="#AAFFFFFF"
    Shell.TabBarBackgroundColor="{StaticResource Surface}"
    Shell.TabBarForegroundColor="{StaticResource Primary}"
    Shell.TabBarUnselectedColor="{StaticResource TextHint}">

    <!-- Login không còn là trang mặc định - App mở thẳng vào Home (Guest Access) -->
    <!-- LoginPage vẫn được đăng ký như route trong AppShell.xaml.cs -->

    <TabBar x:Name="MainTabBar">
        <ShellContent
            x:Name="HomeTab"
            Route="home"
            Title="Home"
            ContentTemplate="{DataTemplate pages:HomePage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="{x:Null}" Glyph="🏠" Size="20" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent
            x:Name="ExploreTab"
            Route="poiList"
            Title="Explore"
            ContentTemplate="{DataTemplate pages:POIListPage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="{x:Null}" Glyph="🔍" Size="20" />
            </ShellContent.Icon>
        </ShellContent>

        <!-- ========================================== -->
        <!--  🟠 CENTER FAB: Scan QR (Tab placeholder) -->
        <!--  Tapping this tab triggers QrScannerPage   -->
        <!-- ========================================== -->
        <ShellContent
            x:Name="ScanQrTab"
            Route="scanQrPlaceholder"
            Title="Scan QR"
            ContentTemplate="{DataTemplate pages:ScanQrPlaceholderPage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="{x:Null}" Glyph="📷" Size="28" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent
            x:Name="TourPlanTab"
            Route="tourPlan"
            Title="Tour Plan"
            ContentTemplate="{DataTemplate pages:TourPlanPage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="{x:Null}" Glyph="🗺️" Size="20" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent
            x:Name="ProfileTab"
            Route="profile"
            Title="Profile"
            ContentTemplate="{DataTemplate pages:ProfilePage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="{x:Null}" Glyph="👤" Size="20" />
            </ShellContent.Icon>
        </ShellContent>
    </TabBar>

</Shell>
