<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ===== PAGE STYLE ===== -->
    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource Background}" />
    </Style>

    <!-- ===== SHELL STYLE ===== -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.ForegroundColor" Value="White" />
        <Setter Property="Shell.TitleColor" Value="White" />
        <Setter Property="Shell.DisabledColor" Value="#40FFFFFF" />
        <Setter Property="Shell.UnselectedColor" Value="#94A3B8" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource TabBarBackground}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TextHint}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource Primary}" />
    </Style>
    
    <!-- ===== BORDER STYLES (NEW) ===== -->
    <Style x:Key="PremiumBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#10000000" Offset="0,10" Radius="20" Opacity="0.8" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GlassBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Glass}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 24" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke" Value="#40FFFFFF" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- ===== LABEL STYLES ===== -->
    <Style x:Key="HeadlineLarge" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsBold" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="HeadlineMedium" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsBold" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="HeadlineSmall" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="TitleLarge" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="TitleMedium" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="BodyLarge" TargetType="Label">
        <Setter Property="FontFamily" Value="Poppins" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineHeight" Value="1.4" />
    </Style>

    <Style x:Key="BodyMedium" TargetType="Label">
        <Setter Property="FontFamily" Value="Poppins" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="BodySmall" TargetType="Label">
        <Setter Property="FontFamily" Value="Poppins" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextHint}" />
    </Style>

    <Style x:Key="LabelCaption" TargetType="Label">
        <Setter Property="FontFamily" Value="Poppins" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor" Value="{StaticResource TextHint}" />
        <Setter Property="CharacterSpacing" Value="0.5" />
    </Style>

    <!-- ===== DEFAULT LABEL ===== -->
    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="Poppins" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <!-- ===== BUTTON STYLES ===== -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="PoppinsBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="Padding" Value="24,0" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource Primary}" Offset="0,8" Radius="15" Opacity="0.4" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="White" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="BorderColor" Value="{StaticResource Border}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="Padding" Value="24,0" />
    </Style>

    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="WidthRequest" Value="48" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <!-- ===== ENTRY STYLES ===== -->
    <Style x:Key="InputEntry" TargetType="Entry">
        <Setter Property="FontFamily" Value="Poppins" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextHint}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="HeightRequest" Value="54" />
    </Style>

    <!-- ===== FRAME / CARD STYLES ===== -->
    <Style x:Key="Card" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="BorderColor" Value="{StaticResource Border}" />
        <Setter Property="HasShadow" Value="True" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#20000000" Offset="0,2" Radius="8" Opacity="0.15" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CardSmall" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="BorderColor" Value="{StaticResource Border}" />
        <Setter Property="HasShadow" Value="True" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- ===== DIVIDER ===== -->
    <Style x:Key="Divider" TargetType="BoxView">
        <Setter Property="Color" Value="{StaticResource Divider}" />
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <!-- ===== SEARCH BAR ===== -->
    <Style TargetType="SearchBar">
        <Setter Property="FontFamily" Value="Poppins" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextHint}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="CancelButtonColor" Value="{StaticResource Primary}" />
    </Style>

    <!-- ===== ACTIVITY INDICATOR ===== -->
    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource Primary}" />
    </Style>

    <!-- ===== SLIDER (audio progress) ===== -->
    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{StaticResource Primary}" />
        <Setter Property="MaximumTrackColor" Value="{StaticResource Border}" />
        <Setter Property="ThumbColor" Value="{StaticResource Primary}" />
    </Style>

</ResourceDictionary>
