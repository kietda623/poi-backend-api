<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ===== PRIMARY PALETTE (INDIGO) ===== -->
    <Color x:Key="Primary">#4F46E5</Color>
    <Color x:Key="PrimaryLight">#818CF8</Color>
    <Color x:Key="PrimaryDark">#3730A3</Color>

    <!-- ===== ACCENT PALETTE (CORAL) ===== -->
    <Color x:Key="Secondary">#F43F5E</Color>
    <Color x:Key="SecondaryLight">#FB7185</Color>
    <Color x:Key="SecondaryDark">#BE123C</Color>

    <!-- Accent - Vàng ánh kim (Gold) -->
    <Color x:Key="Accent">#FBBF24</Color>

    <!-- ===== NEUTRAL PALETTE ===== -->
    <Color x:Key="Background">#F8FAFC</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceVariant">#F1F5F9</Color>
    <Color x:Key="Glass">#B2FFFFFF</Color>

    <!-- Text chính -->
    <Color x:Key="TextPrimary">#0F172A</Color>
    <Color x:Key="TextSecondary">#475569</Color>
    <Color x:Key="TextHint">#94A3B8</Color>

    <!-- ===== SEMANTIC COLORS ===== -->
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Error">#EF4444</Color>
    <Color x:Key="Info">#3B82F6</Color>

    <!-- ===== BORDER & DIVIDER ===== -->
    <Color x:Key="Border">#E2E8F0</Color>
    <Color x:Key="Divider">#F1F5F9</Color>

    <!-- ===== OVERLAY & GRADIENTS ===== -->
    <Color x:Key="Overlay">#800F172A</Color>
    <Color x:Key="CardShadow">#0F4F46E5</Color>
    
    <LinearGradientBrush x:Key="LushPrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Primary}" Offset="0.1" />
        <GradientStop Color="{StaticResource PrimaryLight}" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LushSecondaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Secondary}" Offset="0.1" />
        <GradientStop Color="{StaticResource SecondaryLight}" Offset="1.0" />
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="LaminationGradient" Center="0.5,0.5" Radius="0.8">
        <GradientStop Color="#40FFFFFF" Offset="0" />
        <GradientStop Color="Transparent" Offset="1" />
    </RadialGradientBrush>

    <!-- ===== SPECIFIC ===== -->
    <Color x:Key="NavBarBackground">#FFFFFF</Color>
    <Color x:Key="TabBarBackground">#FFFFFF</Color>
    <Color x:Key="PlayerBackground">#0F172A</Color>
    <Color x:Key="PlayerSurface">#1E293B</Color>
    <Color x:Key="GlassBackground">#40FFFFFF</Color>
    <Color x:Key="GlassBorder">#60FFFFFF</Color>

</ResourceDictionary>